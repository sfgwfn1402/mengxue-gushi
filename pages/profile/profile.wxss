/* pages/profile/profile.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 100%);
}

.container { padding: 28rpx 24rpx 44rpx; box-sizing: border-box; }
.checkin-card,
.profile-header,
.stat-item,
.menu-list,
.reminder {
  background: rgba(255,255,255,0.94);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07);
}

.checkin-card { padding: 28rpx; margin-bottom: 20rpx; }
.checkin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22rpx; }
.checkin-title { font-size: 32rpx; font-weight: 900; color: #1F2937; }
.checkin-streak { font-size: 25rpx; color: #FF6B6B; background: #FFF0F0; padding: 8rpx 16rpx; border-radius: 999rpx; font-weight: 800; }
.streak-week { display: flex; justify-content: space-between; margin-bottom: 22rpx; }
.streak-day { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 12rpx 0; border-radius: 18rpx; }
.streak-day.checked { background: linear-gradient(180deg, #FFF4D6 0%, #FFE7B8 100%); }
.streak-day.today { border: 2rpx solid #FF7A45; }
.streak-dot { font-size: 30rpx; line-height: 1; }
.streak-label { font-size: 22rpx; color: #8A8F98; font-weight: 700; }
.streak-day.checked .streak-label { color: #B5651D; }
.checkin-btn { width: 100%; height: 82rpx; line-height: 82rpx; background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); color: #fff; border-radius: 999rpx; font-size: 30rpx; font-weight: 900; padding: 0; border: none; box-shadow: 0 12rpx 24rpx rgba(255,122,69,0.22); }
.checkin-btn.checked-btn { background: linear-gradient(180deg, #6DD98A 0%, #45B96C 100%); }
.reminder-link { text-align: center; margin-top: 16rpx; font-size: 25rpx; font-weight: 700; color: #FF7A45; }

.profile-header { display: flex; align-items: center; padding: 30rpx; margin-bottom: 20rpx; gap: 20rpx; }
.avatar { width: 112rpx; height: 112rpx; border-radius: 32rpx; background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%); display: flex; align-items: center; justify-content: center; font-size: 56rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.4), 0 12rpx 22rpx rgba(255,173,50,0.18); overflow: hidden; }
.avatar-button { padding: 0; border: none; line-height: normal; flex: 0 0 112rpx; margin: 0; }
.avatar-button::after { border: none; }
.avatar-img { width: 100%; height: 100%; display: block; }
.user-info { flex: 1 1 auto; min-width: 0; overflow: hidden; }
.nickname-input { width: 100%; display: block; font-size: 34rpx; font-weight: 900; color: #1F2937; height: 50rpx; line-height: 50rpx; white-space: nowrap; }
.level { font-size: 26rpx; color: #FF7A45; margin-top: 8rpx; font-weight: 800; white-space: nowrap; }
.login-tip { max-width: 100%; font-size: 22rpx; color: #9AA1AD; line-height: 1.35; margin-top: 8rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.profile-save { width: 96rpx !important; min-width: 96rpx; height: 60rpx; line-height: 60rpx; padding: 0; margin: 0; border-radius: 999rpx; background: linear-gradient(180deg, #71B8FF 0%, #3D8CFF 100%); color: #fff; font-size: 25rpx; font-weight: 900; box-shadow: 0 10rpx 20rpx rgba(61,140,255,0.18); flex: 0 0 96rpx; }
.profile-save::after { border: none; }

.stats { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.stat-item { flex: 1; padding: 24rpx 12rpx; text-align: center; }
.stat-button { margin: 0; border: none; line-height: normal; background: rgba(255,255,255,0.94); }
.stat-button::after { border: none; }
.stat-button:active { transform: scale(0.98); background: #FFF8EA; }
.stat-value { font-size: 40rpx; font-weight: 900; color: #FF6B6B; }
.stat-label { font-size: 23rpx; color: #8A8F98; margin-top: 8rpx; font-weight: 700; }
.stat-hint { display: inline-flex; align-items: center; justify-content: center; margin-top: 12rpx; padding: 5rpx 12rpx; border-radius: 999rpx; background: #FFF0E8; color: #FF7A45; font-size: 20rpx; font-weight: 800; }

.menu-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  padding: 22rpx;
  background: rgba(255,255,255,0.74);
  border-radius: 34rpx;
}
.menu-item {
  position: relative;
  min-height: 188rpx;
  padding: 24rpx 14rpx 20rpx;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 12rpx 26rpx rgba(31,35,46,0.06);
}
.menu-item::before {
  content: '';
  position: absolute;
  right: -28rpx;
  top: -34rpx;
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.42);
}
.menu-button { width: 100%; border: none; margin: 0; text-align: center; line-height: normal; }
.menu-button::after { border: none; }
.menu-button:active { transform: scale(0.97); filter: brightness(0.98); }
.menu-icon-wrap {
  position: relative;
  z-index: 1;
  width: 78rpx;
  height: 78rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.74);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.7), 0 8rpx 16rpx rgba(31,35,46,0.06);
}
.menu-icon { font-size: 42rpx; line-height: 1; }
.menu-text { position: relative; z-index: 1; margin-top: 16rpx; font-size: 29rpx; color: #1F2937; font-weight: 900; }
.menu-desc { position: relative; z-index: 1; margin-top: 8rpx; font-size: 21rpx; color: rgba(31,41,55,0.52); font-weight: 800; }

/* 紧凑图标网格(4列) */
.menu-grid { display: flex; flex-wrap: wrap; padding: 18rpx 6rpx; background: rgba(255,255,255,0.94); border-radius: 30rpx; box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07); }
.menu-grid .menu-cell { width: 25%; box-sizing: border-box; padding: 18rpx 0; margin: 0; display: flex; flex-direction: column; align-items: center; background: transparent; }
.menu-cell::after { border: none; }
.menu-cell:active { transform: scale(0.94); }
.menu-cell-icon { width: 88rpx; height: 88rpx; border-radius: 26rpx; display: flex; align-items: center; justify-content: center; font-size: 44rpx; }
.menu-cell-text { margin-top: 12rpx; font-size: 23rpx; color: #3A4456; font-weight: 800; white-space: nowrap; }
.tone-card { background: #FDF1E0; }
.tone-pink { background: #FFE7F0; }
.tone-orange { background: #FFF0DA; }
.tone-blue { background: #E4F0FF; }
.tone-purple { background: #EEE8FF; }
.tone-green { background: #E5F7EC; }
.tone-gold { background: #FFF3CF; }
.tone-mint { background: #E0F7F2; }
.tone-rose { background: #FFEAEC; }
.tone-gray { background: #EEF1F6; }
.tone-slate { background: #E8ECF4; }
.menu-works { background: linear-gradient(145deg, #FFF4D8 0%, #FFE1A6 100%); }
.menu-favorites { background: linear-gradient(145deg, #EAF7FF 0%, #CFEAFF 100%); }
.menu-records { background: linear-gradient(145deg, #F0EEFF 0%, #DDD6FE 100%); }
.menu-achievements { background: linear-gradient(145deg, #FFF0E8 0%, #FFD2BE 100%); }
.menu-feedback { background: linear-gradient(145deg, #EFFFF5 0%, #C9F5DA 100%); }
.menu-admin { background: linear-gradient(145deg, #FFF4E6 0%, #FFD7A8 100%); }
.menu-settings { background: linear-gradient(145deg, #F4F6FA 0%, #E3E8F0 100%); }

.reminder { margin-top: 28rpx; padding: 30rpx; text-align: center; background: linear-gradient(180deg, #71B8FF 0%, #3D8CFF 100%); box-shadow: 0 16rpx 32rpx rgba(61,140,255,0.20); }
.reminder-title { font-size: 28rpx; color: #fff; font-weight: 900; }
.version-info { margin-top: 18rpx; text-align: center; color: #B0B7C3; font-size: 22rpx; font-weight: 700; }

.modal-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.36); display: flex; align-items: flex-end; z-index: 99; }
.modal-card { width: 100%; max-height: 78vh; background: #fff; border-radius: 34rpx 34rpx 0 0; padding: 30rpx; box-sizing: border-box; overflow-y: auto; box-shadow: 0 -16rpx 42rpx rgba(0,0,0,0.10); }
.modal-header { display: flex; align-items: center; margin-bottom: 20rpx; }
.modal-title { flex: 1; font-size: 34rpx; font-weight: 900; color: #1F2937; }
.modal-close { width: 56rpx; height: 56rpx; line-height: 52rpx; text-align: center; font-size: 44rpx; color: #A0A7B2; }
.modal-text { white-space: pre-line; font-size: 28rpx; color: #5F6672; line-height: 1.8; background: #FFF8EA; border-radius: 22rpx; padding: 24rpx; }
.about-version-list { background: #FFF8EA; border-radius: 22rpx; padding: 24rpx; text-align: left; }
.about-version-row { display: flex; align-items: flex-start; justify-content: flex-start; margin-bottom: 16rpx; font-size: 28rpx; line-height: 1.7; color: #5F6672; text-align: left; }
.about-version-row:last-child { margin-bottom: 0; }
.about-version-label { flex: none; color: #1F2937; font-weight: 900; }
.about-version-value { flex: 1; min-width: 0; color: #5F6672; font-weight: 700; text-align: left; }
.modal-list { display: flex; flex-direction: column; gap: 16rpx; }
.modal-item { background: #FFF8EA; border-radius: 22rpx; padding: 22rpx; }
.modal-item-title { font-size: 30rpx; font-weight: 900; color: #1F2937; }
.modal-item-desc { font-size: 24rpx; color: #8A8F98; margin-top: 8rpx; line-height: 1.5; }

/* 我的诗集 · 成就墙 */
.collection-summary { font-size: 28rpx; font-weight: 900; color: #FF6B6B; margin-bottom: 16rpx; }
.collection-badges { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 18rpx; }
.badge-chip { display: flex; align-items: center; gap: 6rpx; border-radius: 999rpx; padding: 10rpx 18rpx; font-size: 22rpx; font-weight: 800; }
.badge-chip.earned { background: linear-gradient(135deg, #FF9F43, #FF6B6B); color: #fff; box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.3); }
.badge-chip.locked { background: #F1F2F4; color: #B5BAC2; }
.badge-icon { font-size: 24rpx; }
.collection-share-btn {
  margin: 4rpx 0 18rpx;
  text-align: center;
  font-size: 28rpx; font-weight: 800; color: #7A3E00;
  background: linear-gradient(135deg, #FFD36B, #FFB347);
  border-radius: 999rpx; padding: 22rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(255, 160, 60, 0.28);
}
.collection-share-btn.loading { opacity: 0.6; }
.collection-share-friend {
  margin: 0 0 18rpx;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 28rpx; font-weight: 800; color: #fff;
  background: linear-gradient(135deg, #FF8A5B, #FF6B6B);
  border-radius: 999rpx; padding: 0;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.28);
}
.collection-share-friend::after { border: none; }
.collection-canvas {
  position: fixed; left: -9999rpx; top: -9999rpx;
  width: 600px; height: 900px; pointer-events: none;
}
.collection-empty { font-size: 26rpx; color: #8A6D3B; background: #FFF8EA; border-radius: 18rpx; padding: 22rpx; margin-bottom: 18rpx; }
.collection-group { margin-bottom: 24rpx; }
.collection-group-title { font-size: 26rpx; font-weight: 900; color: #1F2937; margin-bottom: 14rpx; }
.collection-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }
.collection-cell { width: calc((100% - 42rpx) / 4); box-sizing: border-box; min-height: 100rpx; border-radius: 18rpx; padding: 14rpx 8rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.cell-stars { font-size: 22rpx; line-height: 1; min-height: 26rpx; }
.cell-title { font-size: 24rpx; font-weight: 700; margin-top: 8rpx; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.state-untouched { background: #F1F2F4; }
.state-untouched .cell-title { color: #B5BAC2; }
.state-learning { background: #FFF1D6; }
.state-learning .cell-title { color: #8A6D3B; }
.state-learned { background: linear-gradient(135deg, #FFE08A, #FFB347); box-shadow: 0 4rpx 10rpx rgba(255,160,60,0.25); }
.state-learned .cell-title { color: #7A3E00; }

.recent-result {
  position: relative;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FFF4CE 0%, #FFE3D6 54%, #FFEFF4 100%);
  border: 1rpx solid rgba(255, 186, 92, 0.42);
  box-shadow: 0 16rpx 36rpx rgba(255, 122, 69, 0.12);
}

.recent-glow {
  position: absolute;
  right: -52rpx;
  top: -58rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.42);
}

.recent-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #9A5B00;
  font-size: 24rpx;
  font-weight: 900;
}

.recent-head text {
  color: rgba(154,91,0,0.62);
  font-size: 21rpx;
  font-weight: 800;
}

.recent-title {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  color: #1F2937;
  font-size: 34rpx;
  font-weight: 950;
  line-height: 1.35;
}

.recent-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #7C5B21;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 750;
}

.recent-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.recent-action {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.74);
  color: #8A5A10;
  font-size: 24rpx;
  font-weight: 900;
}

.recent-action::after { border: none; }
.recent-action.primary { background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); color: #fff; box-shadow: 0 10rpx 18rpx rgba(255,122,69,0.16); }

/* 邀请裂变卡片 */
.invite-card {
  background: linear-gradient(135deg, #FFF9E6 0%, #FFF0D6 100%);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,177,93,0.3);
  box-shadow: 0 16rpx 36rpx rgba(255,122,69,0.09);
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.invite-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}
.invite-title { font-size: 30rpx; font-weight: 900; color: #1F2937; }
.invite-badge-chip {
  font-size: 22rpx;
  font-weight: 800;
  color: #B5651D;
  background: linear-gradient(180deg, #FFE7B8 0%, #FFD080 100%);
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
}
.invite-stats {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.invite-num {
  font-size: 64rpx;
  font-weight: 900;
  color: #FF7A45;
  line-height: 1;
}
.invite-num-label { font-size: 24rpx; color: #8A5A10; font-weight: 700; }
.invite-progress { font-size: 22rpx; color: #B5651D; margin-left: auto; background: rgba(255,177,93,0.18); padding: 6rpx 14rpx; border-radius: 999rpx; }
.invite-badges {
  display: flex;
  gap: 12rpx;
  margin-bottom: 22rpx;
}
.invite-badge-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.5);
  border: 2rpx solid rgba(255,177,93,0.2);
  font-size: 20rpx;
  color: #BDB5AA;
  font-weight: 700;
  opacity: 0.55;
}
.invite-badge-item text:first-child { font-size: 32rpx; }
.invite-badge-item.earned {
  opacity: 1;
  color: #B5651D;
  background: linear-gradient(180deg, #FFF4D6 0%, #FFE7B8 100%);
  border-color: #FFB15D;
}
.invite-btn {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 900;
  padding: 0;
  border: none;
  box-shadow: 0 12rpx 24rpx rgba(255,122,69,0.22);
}
.invite-btn::after { border: none; }
