<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="profile-header">
    <button class="avatar avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
      <text wx:else>👶</text>
    </button>
    <view class="user-info">
      <input class="nickname-input" type="nickname" placeholder="给小诗人起个昵称" value="{{nicknameInput}}" bindinput="onNicknameInput" />
      <view class="level">Lv.{{level}} 启蒙学者</view>
      <view class="login-tip">微信静默登录已开启，学习记录会跟随当前微信账号</view>
    </view>
    <button class="profile-save" bindtap="saveProfile" loading="{{profileSaving}}" disabled="{{profileSaving}}">保存</button>
  </view>

  <view class="checkin-card">
    <view class="checkin-header">
      <view class="checkin-title">🔥 学习打卡</view>
      <view class="checkin-streak">连续 {{streak}} 天</view>
    </view>
    <view class="streak-week">
      <view class="streak-day {{item.checked ? 'checked' : ''}} {{item.today ? 'today' : ''}}" wx:for="{{recentDays}}" wx:key="index">
        <text class="streak-dot">{{item.checked ? '🔥' : '·'}}</text>
        <text class="streak-label">{{item.label}}</text>
      </view>
    </view>
    <button class="checkin-btn {{todayChecked ? 'checked-btn' : ''}}" bindtap="doCheckin" disabled="{{todayChecked}}">
      {{todayChecked ? '✅ 今日已打卡' : '📌 立即打卡'}}
    </button>
    <view class="reminder-link" bindtap="openStudyReminder">🔔 开启每日学习提醒</view>
  </view>

  <view class="stats">
    <button class="stat-item stat-button" data-type="poems" bindtap="handleStatTap">
      <view class="stat-value">{{learnedCount}}</view><view class="stat-label">古诗</view><view class="stat-hint">查看已学</view>
    </button>
    <button class="stat-item stat-button" data-type="days" bindtap="handleStatTap">
      <view class="stat-value">{{totalDays}}</view><view class="stat-label">学习天数</view><view class="stat-hint">学习记录</view>
    </button>
  </view>

  <view class="recent-result" wx:if="{{recentResult}}">
    <view class="recent-glow"></view>
    <view class="recent-head">
      <view>✨ 最近成长</view>
      <text>{{recentResultDate}}</text>
    </view>
    <view class="recent-title">{{recentResultText}}</view>
    <view class="recent-subtitle">趁热录一段朗诵，或放进我的诗集慢慢收藏。</view>
    <view class="recent-actions">
      <button class="recent-action primary" bindtap="createRecentRecitation">{{recentActionText || '录朗诵'}}</button>
      <button class="recent-action" bindtap="openRecentPoem">再看看</button>
      <button class="recent-action" bindtap="openMyWorks">诗集</button>
    </view>
  </view>

  <view class="invite-card">
    <view class="invite-head">
      <view class="invite-title">👥 邀请好友学古诗</view>
      <view wx:if="{{inviteBadge}}" class="invite-badge-chip">{{inviteBadge}} {{inviteBadgeLabel}}</view>
    </view>
    <view class="invite-stats">
      <view class="invite-num">{{inviteCount}}</view>
      <view class="invite-num-label">已成功邀请</view>
      <view wx:if="{{inviteNextAt && inviteNextAt > inviteCount}}" class="invite-progress">再邀 {{inviteNextAt - inviteCount}} 人解锁下一勋章</view>
      <view wx:elif="{{!inviteNextAt}}" class="invite-progress">已达最高等级 👑</view>
    </view>
    <view class="invite-badges">
      <view class="invite-badge-item {{inviteCount >= 1 ? 'earned' : ''}}"><text>🎖</text><text>小推官</text><text>×1</text></view>
      <view class="invite-badge-item {{inviteCount >= 3 ? 'earned' : ''}}"><text>📜</text><text>传播者</text><text>×3</text></view>
      <view class="invite-badge-item {{inviteCount >= 5 ? 'earned' : ''}}"><text>🌟</text><text>诗坛大使</text><text>×5</text></view>
      <view class="invite-badge-item {{inviteCount >= 10 ? 'earned' : ''}}"><text>👑</text><text>诗坛领袖</text><text>×10</text></view>
    </view>
    <button class="invite-btn" bindtap="shareInvite" open-type="share" data-share-type="invite">分享邀请，一起学古诗 →</button>
  </view>

  <view class="menu-grid">
    <button class="menu-cell menu-button" data-action="cards" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-card">🃏</view><text class="menu-cell-text">古诗卡册</text>
    </button>
    <button class="menu-cell menu-button" data-action="my-moments" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-pink">💬</view><text class="menu-cell-text">我的动态</text>
    </button>
    <button class="menu-cell menu-button" data-action="works" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-orange">🎧</view><text class="menu-cell-text">我的诗集</text>
    </button>
    <button class="menu-cell menu-button" data-action="favorites" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-blue">📚</view><text class="menu-cell-text">我的收藏</text>
    </button>
    <button class="menu-cell menu-button" data-action="records" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-purple">📖</view><text class="menu-cell-text">学习记录</text>
    </button>
    <button class="menu-cell menu-button" data-action="parent-report" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-green">📊</view><text class="menu-cell-text">家长周报</text>
    </button>
    <button class="menu-cell menu-button" data-action="achievements" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-gold">🏆</view><text class="menu-cell-text">成就墙</text>
    </button>
    <button class="menu-cell menu-button" data-action="feedback" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-mint">💬</view><text class="menu-cell-text">家长心声</text>
    </button>
    <button class="menu-cell menu-button" data-action="voice-agreement" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-rose">🎙</view><text class="menu-cell-text">声纹授权</text>
    </button>
    <button class="menu-cell menu-button" data-action="settings" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-gray">⚙️</view><text class="menu-cell-text">设置</text>
    </button>
    <button wx:if="{{isAdmin}}" class="menu-cell menu-button" data-action="admin" bindtap="handleMenuTap">
      <view class="menu-cell-icon tone-slate">🛠</view><text class="menu-cell-text">管理中心</text>
    </button>
  </view>

  <view class="reminder"><view class="reminder-title">{{encourageMessage}}</view></view>

  <view class="version-info">v{{appVersion}}</view>

  <view class="modal-mask" wx:if="{{modalVisible}}" bindtap="closeModal">
    <view class="modal-card" catchtap="noop">
      <view class="modal-header">
        <view class="modal-title">{{modalTitle}}</view>
        <view class="modal-close" bindtap="closeModal">×</view>
      </view>
      <view wx:if="{{modalText}}" class="modal-text">{{modalText}}</view>
      <view wx:if="{{modalType === 'about'}}" class="about-version-list">
        <view class="about-version-row" wx:for="{{aboutLines}}" wx:key="label">
          <text class="about-version-label">{{item.label}}：</text>
          <text class="about-version-value">{{item.value}}</text>
        </view>
      </view>
      <view wx:if="{{modalItems.length}}" class="modal-list">
        <view class="modal-item" wx:for="{{modalItems}}" wx:key="index" bindtap="openModalItem" data-index="{{index}}">
          <view class="modal-item-title">{{item.title}}</view>
          <view class="modal-item-desc">{{item.desc}}</view>
        </view>
      </view>
      <view wx:if="{{modalType === 'collection'}}" class="collection-wrap">
        <view class="collection-summary">已点亮 {{collectionLearned}}/{{collectionTotal}}</view>
        <view class="collection-badges">
          <view class="badge-chip {{item.earned ? 'earned' : 'locked'}}" wx:for="{{collectionBadges}}" wx:key="value">
            <text class="badge-icon">{{item.earned ? '🏆' : '🔒'}}</text>
            <text class="badge-label">学会{{item.value}}首</text>
          </view>
        </view>
        <view wx:if="{{collectionLearned}}" class="collection-share-btn {{collectionCardGenerating ? 'loading' : ''}}" bindtap="shareCollectionCard">
          📤 生成成就卡，晒给家人看
        </view>
        <button wx:if="{{shareCardPath}}" class="collection-share-friend" open-type="share" data-share-type="card">🎁 把成就卡分享给好友</button>
        <view wx:if="{{collectionEmptyHint}}" class="collection-empty">{{collectionEmptyHint}}</view>
        <view class="collection-group" wx:for="{{collectionGroups}}" wx:key="key" wx:for-item="group">
          <view class="collection-group-title">{{group.label}} {{group.learned}}/{{group.total}}</view>
          <view class="collection-grid">
            <view class="collection-cell state-{{cell.state}}" wx:for="{{group.cells}}" wx:key="id" wx:for-item="cell" bindtap="openCollectionCell" data-id="{{cell.id}}">
              <view class="cell-stars">{{cell.stars}}</view>
              <view class="cell-title">{{cell.title}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <canvas canvas-id="collectionCard" class="collection-canvas"></canvas>
</view>
