page { min-height: 100vh; background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 100%); }
.container { padding: 28rpx 24rpx 44rpx; box-sizing: border-box; }
.header-card { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-radius: 32rpx; background: linear-gradient(145deg, #FFF4E6 0%, #FFD7A8 100%); box-shadow: 0 18rpx 38rpx rgba(255,149,0,0.14); margin-bottom: 20rpx; }
.page-title { font-size: 38rpx; font-weight: 900; color: #1F2937; }
.page-sub { margin-top: 8rpx; font-size: 24rpx; color: #8A5A18; font-weight: 800; }
.status-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.status-tabs { display: inline-flex; gap: 12rpx; }
.status-tab { padding: 14rpx 24rpx; border-radius: 999rpx; background: #fff; color: #8A8F98; font-size: 25rpx; font-weight: 900; box-shadow: 0 8rpx 20rpx rgba(31,35,46,0.06); }
.status-tab.active { color: #fff; background: linear-gradient(135deg, #FFB15D 0%, #FF7A45 100%); }
.feedback-list { display: flex; flex-direction: column; gap: 18rpx; }
.feedback-card { padding: 26rpx; border-radius: 30rpx; background: rgba(255,255,255,0.96); box-shadow: 0 14rpx 32rpx rgba(31,35,46,0.08); }
.card-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; color: #1F2937; font-weight: 900; }
.card-time { margin-top: 6rpx; color: #9AA1AD; font-size: 23rpx; font-weight: 700; }
.status-pill { flex: none; padding: 8rpx 16rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 900; background: #F1F5F9; color: #64748B; }
.status-pending { background: #FFF4D6; color: #B86B00; }
.status-resolved { background: #EFFFF5; color: #20A45B; }
.status-ignored { background: #F1F5F9; color: #64748B; }
.field-block { margin-top: 16rpx; padding: 18rpx; border-radius: 20rpx; background: #FFF8EA; }
.field-block.contact { background: #F6F8FC; }
.field-label { font-size: 23rpx; color: #A66A23; font-weight: 900; margin-bottom: 6rpx; }
.field-text { color: #3B4250; font-size: 27rpx; line-height: 1.65; font-weight: 700; word-break: break-all; }
.card-actions { display: flex; justify-content: flex-end; margin-top: 18rpx; }
.action-btn { margin: 0; height: 64rpx; line-height: 64rpx; padding: 0 24rpx; border-radius: 999rpx; font-size: 25rpx; font-weight: 900; border: none; }
.action-btn::after { border: none; }
.action-btn.done { color: #fff; background: linear-gradient(135deg, #45D483 0%, #20A45B 100%); }
.empty, .loading, .no-more { padding: 40rpx 0; text-align: center; color: #9AA1AD; font-size: 25rpx; font-weight: 800; }
