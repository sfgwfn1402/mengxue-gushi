/* pages/learn/learn.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 58%, #FFF2DE 100%);
  color: #1D1D1F;
}

.container {
  padding: 28rpx 24rpx 44rpx;
  box-sizing: border-box;
}

.back {
  display: inline-flex;
  align-items: center;
  height: 60rpx;
  padding: 0 24rpx 0 18rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #FF7A45;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 10rpx 24rpx rgba(31, 35, 46, 0.06);
}

.back:active {
  transform: scale(0.97);
  opacity: 0.86;
}

.card {
  position: relative;
  overflow: hidden;
  padding: 36rpx 30rpx 34rpx;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow: 0 22rpx 50rpx rgba(33, 37, 48, 0.10), 0 4rpx 12rpx rgba(33, 37, 48, 0.04);
}

.card::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 209, 102, 0.34) 0%, rgba(255, 209, 102, 0) 68%);
  pointer-events: none;
}

.card-header {
  position: relative;
  z-index: 1;
  margin-bottom: 18rpx;
  text-align: center;
}

.poem-card-header {
  min-height: 52rpx;
}

.favorite-pill {
  position: absolute;
  top: 0;
  right: 0;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #FF6B6B;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid rgba(255, 147, 147, 0.35);
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 107, 0.10), inset 0 1rpx 0 rgba(255,255,255,0.85);
}

.favorite-pill.active {
  color: #fff;
  background: linear-gradient(180deg, #FF8FA3 0%, #FF5A6E 100%);
  border-color: transparent;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: #9A5B00;
  background: linear-gradient(180deg, #FFF3C5 0%, #FFE19A 100%);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(255, 190, 80, 0.18);
}

.poem-illustration {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 360rpx;
  display: block;
  margin: 0 0 28rpx;
  border-radius: 30rpx;
  background: #FFF4D8;
  box-shadow: 0 16rpx 34rpx rgba(120, 72, 22, 0.14);
}

.poem-title {
  position: relative;
  z-index: 1;
  margin-top: 4rpx;
  margin-bottom: 8rpx;
  text-align: center;
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #1F2937;
  letter-spacing: 2rpx;
}

.poem-author {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  text-align: center;
  font-size: 27rpx;
  font-weight: 600;
  color: #8A8F98;
}

.top-actions {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 18rpx;
  margin: 8rpx 0 28rpx;
}

.top-actions.has-featured {
  justify-content: space-between;
}

.top-read-btn {
  min-width: 320rpx;
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 36rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 900;
  color: #fff;
  background: linear-gradient(180deg, #5AB8FF 0%, #1E88FF 100%);
  box-shadow: 0 14rpx 26rpx rgba(30, 136, 255, 0.25), inset 0 1rpx 0 rgba(255,255,255,0.40);
}

.has-featured .top-read-btn {
  min-width: 0;
  width: 318rpx;
  padding: 0 14rpx;
}

.top-read-btn.featured {
  background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%);
  box-shadow: 0 14rpx 26rpx rgba(255, 173, 50, 0.25), inset 0 1rpx 0 rgba(255,255,255,0.48);
}

.top-read-btn.playing {
  background: linear-gradient(180deg, #9CA3AF 0%, #6B7280 100%);
  box-shadow: 0 12rpx 22rpx rgba(80, 88, 102, 0.20);
}

.top-read-btn:active,
.record-main-btn:active,
.tool-btn:active,
.rank-icon:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.featured-read-wrap {
  width: 318rpx;
  text-align: center;
}

.featured-from {
  margin-top: 9rpx;
  padding: 0 10rpx;
  color: #A66A23;
  font-size: 22rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poem-reader {
  position: relative;
  z-index: 1;
  height: 540rpx;
  max-height: 540rpx;
  padding: 22rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  overflow: hidden;
  scroll-padding-top: 190rpx;
  background: linear-gradient(180deg, #FFF8E8 0%, #FFF1D6 100%);
  border: 1rpx solid rgba(255, 214, 148, 0.58);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.76);
}

.poem-reader-spacer {
  height: 0;
}

.poem-reader.reading .poem-reader-spacer {
  height: 168rpx;
}

.poem-line {
  position: relative;
  z-index: 1;
  min-height: 82rpx;
  line-height: 1.72;
  margin: 10rpx 4rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  text-align: center;
  font-size: 42rpx;
  font-weight: 800;
  color: #3B342A;
  letter-spacing: 4rpx;
  transform: scale(1);
  transform-origin: center center;
  transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1), color 0.25s ease, background 0.25s ease, opacity 0.25s ease, box-shadow 0.25s ease;
}

.poem-line.active {
  z-index: 2;
  min-height: 124rpx;
  line-height: 1.86;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  font-size: 52rpx;
  font-weight: 900;
  color: #FF6B2C;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 34rpx rgba(255, 130, 70, 0.22), inset 0 1rpx 0 rgba(255,255,255,0.9);
  transform: scale(1.06);
}

.poem-line.inactive {
  opacity: 0.5;
}

.poem-line.done {
  color: #B7A98F;
}

.line-speaker {
  margin-right: 10rpx;
  font-size: 34rpx;
}

.rich-line {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rpx;
}

.char-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  min-width: 52rpx;
  margin: 0 2rpx 12rpx;
}

.char-cell.punct {
  min-width: 24rpx;
}

.char-pinyin {
  min-height: 30rpx;
  line-height: 30rpx;
  color: #A67C52;
  font-size: 21rpx;
  font-weight: 800;
  letter-spacing: 0;
  white-space: nowrap;
}

.char-text {
  line-height: 1.15;
  color: inherit;
  font-size: 42rpx;
  font-weight: inherit;
  letter-spacing: 0;
}

.poem-line.active .char-pinyin {
  color: #D97706;
  font-size: 23rpx;
}

.poem-line.active .char-text {
  font-size: 52rpx;
}

.reading-hint {
  text-align: center;
  color: #B86B00;
  font-size: 25rpx;
  font-weight: 700;
  margin: 4rpx 0 20rpx;
}

.section {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(31, 35, 46, 0.04);
  box-shadow: 0 10rpx 26rpx rgba(31, 35, 46, 0.06);
}

.section-title {
  margin-bottom: 14rpx;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #FF6B6B;
}

.section-content {
  font-size: 28rpx;
  color: #5F6672;
  line-height: 1.85;
}

.recitation-section {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
  padding: 26rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,248,234,0.96) 100%);
  border: 1rpx solid rgba(255, 216, 138, 0.58);
  box-shadow: 0 18rpx 42rpx rgba(184, 107, 0, 0.09), inset 0 1rpx 0 rgba(255,255,255,0.80);
}

.recitation-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.recitation-icon {
  flex-shrink: 0;
  width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 22rpx;
  text-align: center;
  font-size: 36rpx;
  background: linear-gradient(180deg, #FFF4D8 0%, #FFE3A4 100%);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.88);
}

.recitation-copy {
  flex: 1;
  min-width: 0;
}

.recitation-title {
  font-size: 34rpx;
  line-height: 1.2;
  color: #1F2937;
  font-weight: 900;
}

.recitation-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.25;
  color: #9A6A2E;
}

.record-status {
  flex-shrink: 0;
  min-width: 92rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 23rpx;
  font-weight: 800;
  color: #B27400;
  background: #FFF4D8;
  border: 1rpx solid #FFD98A;
}

.record-status.live {
  color: #fff;
  background: linear-gradient(180deg, #FF7A85 0%, #FF5A6E 100%);
  border-color: transparent;
}

.record-status.ready {
  color: #fff;
  background: linear-gradient(180deg, #6DD98A 0%, #45B96C 100%);
  border-color: transparent;
}

.record-panel {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.88);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.86), 0 8rpx 22rpx rgba(31,35,46,0.05);
}

.record-main-btn {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 24rpx;
  text-align: center;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%);
  box-shadow: 0 12rpx 24rpx rgba(255, 122, 69, 0.22), inset 0 1rpx 0 rgba(255,255,255,0.35);
}

.record-main-btn.recording {
  background: linear-gradient(180deg, #FF7A85 0%, #E84A5F 100%);
}

.pulse-dot {
  margin-right: 12rpx;
  animation: pulseDot 1s infinite;
}

@keyframes pulseDot {
  0% { opacity: 0.35; }
  50% { opacity: 1; }
  100% { opacity: 0.35; }
}

.record-tools {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.tool-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 22rpx;
  text-align: center;
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.30), 0 8rpx 18rpx rgba(31,35,46,0.08);
}

.tool-btn.preview {
  background: linear-gradient(180deg, #71B8FF 0%, #3D8CFF 100%);
}

.tool-btn.upload {
  background: linear-gradient(180deg, #6BD987 0%, #45B96C 100%);
}

.tool-btn.disabled {
  opacity: 0.55;
}

.record-tip {
  margin-top: 14rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.35;
  color: #9A6A2E;
}

.rank-block {
  margin-top: 24rpx;
}

.rank-title-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.rank-title {
  font-size: 31rpx;
  color: #1F2937;
  font-weight: 900;
}

.rank-subtitle {
  font-size: 23rpx;
  font-weight: 800;
  color: #B8860B;
  background: #FFF0D0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.empty-rank {
  padding: 28rpx 20rpx;
  border-radius: 24rpx;
  color: #9A6A2E;
  font-size: 26rpx;
  text-align: center;
  background: rgba(255,255,255,0.86);
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(31,35,46,0.055);
}

.rank-no {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  background: linear-gradient(180deg, #C6C8CE 0%, #9CA3AF 100%);
}

.rank-no.top {
  background: linear-gradient(180deg, #FFE27A 0%, #FFAF32 100%);
  box-shadow: 0 8rpx 16rpx rgba(255, 175, 50, 0.22);
}

.rank-user {
  flex: 1;
  min-width: 0;
}

.rank-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  line-height: 1.25;
  color: #1F2937;
  font-weight: 900;
}

.rank-meta {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 23rpx;
  line-height: 1.25;
  color: #8A8F98;
  margin-top: 6rpx;
}

.rank-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.rank-icon {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 50%;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.8), 0 6rpx 14rpx rgba(31,35,46,0.06);
}

.rank-icon.play {
  color: #1E88FF;
  background: #EAF4FF;
}

.rank-icon.like {
  color: #B9A890;
  background: #FFF3E4;
}

.rank-icon.like.liked {
  color: #FF5A6E;
  background: #FFE4EA;
}

.parent-guide {
  overflow: hidden;
  background: linear-gradient(180deg, #FFF9EF 0%, #FFF2DF 100%);
  border-radius: 28rpx;
  padding: 22rpx;
  border: 1rpx solid #FFE1B3;
}

.parent-guide-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.parent-guide-icon {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 22rpx;
  text-align: center;
  font-size: 34rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 18rpx rgba(184, 107, 0, 0.09);
}

.parent-guide-copy {
  flex: 1;
  min-width: 0;
}

.parent-guide .section-title {
  margin-bottom: 6rpx;
  color: #B86B00;
}

.parent-guide-subtitle,
.parent-guide-preview {
  color: #9A6A2E;
  font-size: 24rpx;
  line-height: 1.45;
}

.parent-guide-toggle {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #B86B00;
  background: rgba(255,255,255,0.78);
  border: 1rpx solid rgba(255, 210, 140, 0.88);
  font-size: 24rpx;
  font-weight: 900;
}

.parent-guide-preview {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.62);
}

.parent-guide .section-content {
  color: #5C3A21;
  line-height: 1.9;
}

.parent-guide-content {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx dashed rgba(184, 107, 0, 0.22);
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
}

.btn {
  flex: 1;
  height: 86rpx;
  line-height: 86rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 900;
  border: none;
}

.btn-primary {
  color: #fff;
  background: linear-gradient(180deg, #5AB8FF 0%, #1E88FF 100%);
  box-shadow: 0 12rpx 24rpx rgba(30, 136, 255, 0.22);
}

.btn-secondary {
  color: #FF6B6B;
  background: rgba(255,255,255,0.94);
  border: 1rpx solid rgba(255,107,107,0.18);
  box-shadow: 0 10rpx 22rpx rgba(31,35,46,0.06);
}

.btn-stop {
  color: #fff;
  background: linear-gradient(180deg, #9CA3AF 0%, #6B7280 100%);
}

.progress {
  margin-top: 32rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 25rpx;
  font-weight: 700;
  color: #8A8F98;
  background: rgba(255,255,255,0.72);
  box-shadow: 0 8rpx 18rpx rgba(31,35,46,0.045);
}

.three-actions {
  gap: 12rpx;
}

.three-actions .btn {
  font-size: 25rpx;
}

.btn-learned {
  color: #fff;
  background: linear-gradient(180deg, #6DD98A 0%, #45B96C 100%);
  box-shadow: 0 12rpx 24rpx rgba(69, 185, 108, 0.22);
}

/* 逐句跟读 */
.follow-section {
  position: relative;
  z-index: 1;
  margin: 24rpx 0 28rpx;
  padding: 26rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #F0F9FF 0%, #FFF7E8 100%);
  border: 1rpx solid rgba(125, 211, 252, 0.45);
  box-shadow: 0 16rpx 32rpx rgba(14, 116, 144, 0.08);
}
.follow-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.follow-title { font-size: 32rpx; font-weight: 900; color: #1F2937; }
.follow-subtitle { margin-top: 8rpx; font-size: 24rpx; color: #6B7280; font-weight: 700; line-height: 1.45; }
.follow-stars { flex-shrink: 0; padding: 10rpx 16rpx; border-radius: 999rpx; background: #FFF3C5; color: #B45309; font-size: 24rpx; font-weight: 900; }
.follow-line-card { margin-top: 22rpx; padding: 24rpx; border-radius: 26rpx; background: rgba(255,255,255,0.92); text-align: center; }
.follow-step { font-size: 23rpx; color: #0EA5E9; font-weight: 900; }
.follow-line { margin-top: 10rpx; font-size: 42rpx; line-height: 1.55; color: #1F2937; font-weight: 900; letter-spacing: 3rpx; }
.follow-progress-dots { display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; margin: 22rpx 0; }
.follow-dot { width: 48rpx; height: 48rpx; line-height: 48rpx; text-align: center; border-radius: 50%; background: #E5E7EB; color: #6B7280; font-size: 22rpx; font-weight: 900; }
.follow-dot.active { background: #38BDF8; color: #fff; transform: scale(1.08); }
.follow-dot.done { background: #FACC15; color: #92400E; }
.follow-actions { display: grid; grid-template-columns: 1fr; gap: 14rpx; }
.follow-btn { height: 76rpx; line-height: 76rpx; border-radius: 999rpx; color: #fff; font-size: 27rpx; font-weight: 900; }
.follow-btn.listen { background: linear-gradient(180deg,#60A5FA,#2563EB); }
.follow-btn.record { background: linear-gradient(180deg,#FB7185,#E11D48); }
.follow-btn.record.recording { background: linear-gradient(180deg,#9CA3AF,#4B5563); }
.follow-btn.done { background: linear-gradient(180deg,#34D399,#059669); }
.follow-tip { margin-top: 16rpx; text-align: center; color: #0F766E; font-size: 25rpx; font-weight: 800; }
.follow-tip.complete { color: #B45309; }

/* 跟读入口：默认收起 */
.follow-entry {
  position: relative;
  z-index: 1;
  margin: 22rpx 0 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, #F0F9FF 0%, #FFFDF7 100%);
  border: 1rpx solid rgba(125, 211, 252, 0.42);
  box-shadow: 0 14rpx 30rpx rgba(14, 116, 144, 0.07);
  overflow: hidden;
}
.follow-entry-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; padding: 24rpx 26rpx; }
.follow-entry-title { font-size: 31rpx; font-weight: 900; color: #1F2937; }
.follow-entry-subtitle { margin-top: 8rpx; font-size: 24rpx; color: #6B7280; font-weight: 700; }
.follow-entry-right { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.follow-stars-mini { padding: 8rpx 14rpx; border-radius: 999rpx; background: #FFF3C5; color: #B45309; font-size: 23rpx; font-weight: 900; }
.follow-chevron { font-size: 23rpx; color: #0EA5E9; font-weight: 900; }
.follow-section.compact { margin: 0; border: none; border-top: 1rpx solid rgba(125, 211, 252, 0.35); border-radius: 0; box-shadow: none; background: transparent; }
.follow-state { margin-top: 12rpx; font-size: 25rpx; color: #0F766E; font-weight: 900; }
.follow-main-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 20rpx; }
.follow-primary, .follow-secondary { height: 78rpx; line-height: 78rpx; border-radius: 999rpx; color: #fff; font-size: 27rpx; font-weight: 900; }
.follow-primary { background: linear-gradient(180deg,#60A5FA,#2563EB); }
.follow-secondary { background: linear-gradient(180deg,#34D399,#059669); }
.follow-secondary.recording { background: linear-gradient(180deg,#FB7185,#E11D48); }
.follow-small-actions { display: flex; justify-content: center; gap: 34rpx; margin-top: 18rpx; color: #0EA5E9; font-size: 25rpx; font-weight: 900; }
.follow-main-actions.single { grid-template-columns: 1fr; }
.follow-primary.single { width: 100%; }
.follow-primary.single.recording { background: linear-gradient(180deg,#34D399,#059669); }
.follow-primary.single.preview { background: linear-gradient(180deg,#A78BFA,#7C3AED); }
.follow-primary.single.playing { background: linear-gradient(180deg,#93C5FD,#60A5FA); }

/* 跟读按钮收紧 + 录音状态 */
.follow-main-actions.single { margin-top: 14rpx; display: flex; justify-content: center; }
.follow-primary.single {
  width: 360rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 28rpx;
  box-shadow: 0 12rpx 24rpx rgba(37,99,235,0.18);
}
.follow-recording-state {
  margin-top: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(254, 226, 226, 0.95);
  color: #DC2626;
  font-size: 25rpx;
  font-weight: 900;
}
.recording-dot {
  color: #EF4444;
  font-size: 28rpx;
  animation: recordingPulse 1s infinite ease-in-out;
}
@keyframes recordingPulse {
  0%, 100% { opacity: 0.45; transform: scale(0.85); }
  50% { opacity: 1; transform: scale(1.15); }
}

/* 修正微信 button 默认样式导致文字偏下 */
.follow-primary.single {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
  box-sizing: border-box;
}
.follow-primary.single::after {
  border: none;
}
.follow-debug { margin-top: 10rpx; font-size: 20rpx; color: #94A3B8; word-break: break-all; line-height: 1.35; }
.follow-debug { display: none; }

/* 当前页沉浸式跟读层：避免 navigateTo + 强制横屏导致 routeDone 系统错误 */
.immersive-follow {
  position: fixed;
  z-index: 9999;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #111827;
  color: #fff;
}

.immersive-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.immersive-bg.fallback {
  background: radial-gradient(circle at 25% 30%, #FFE2A8 0%, transparent 32%), linear-gradient(135deg, #243B53 0%, #0F172A 62%, #381D1D 100%);
}

.immersive-veil {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 48%, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.01) 28%, rgba(0,0,0,0.38) 72%),
    linear-gradient(90deg, rgba(8,13,25,0.60) 0%, rgba(8,13,25,0.16) 46%, rgba(8,13,25,0.62) 100%);
}

.immersive-head {
  position: relative;
  z-index: 2;
  height: 108rpx;
  padding: 18rpx 28rpx 0;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 150rpx 1fr 126rpx;
  align-items: center;
  gap: 18rpx;
}

.immersive-back,
.immersive-count {
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.50);
  border: 1rpx solid rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.92);
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.immersive-title-wrap {
  min-width: 0;
  text-align: center;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.46);
}

.immersive-title {
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #FFF2C2;
  letter-spacing: 3rpx;
}

.immersive-author {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.74);
  font-weight: 700;
}

.immersive-body {
  position: relative;
  z-index: 2;
  height: calc(100vh - 108rpx);
  padding: 10rpx 28rpx 26rpx;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 210rpx 1fr 190rpx;
  gap: 20rpx;
  align-items: center;
}

.immersive-side {
  align-self: stretch;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 24rpx 18rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  background: rgba(15, 23, 42, 0.36);
  border: 1rpx solid rgba(255,255,255,0.14);
}

.immersive-tag {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 213, 111, 0.18);
  color: #FFE2A8;
  font-size: 21rpx;
  font-weight: 900;
}

.immersive-state {
  margin-top: 26rpx;
  font-size: 36rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #A7D8FF;
}

.immersive-state.rec { color: #FFB4B4; }
.immersive-state.done { color: #A7F3D0; }

.immersive-hint {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255,255,255,0.70);
}

.immersive-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.immersive-line-card {
  width: 100%;
  min-height: 220rpx;
  padding: 34rpx 42rpx 38rpx;
  box-sizing: border-box;
  border-radius: 44rpx;
  background: transparent;
  border: 1rpx solid transparent;
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.immersive-line-index {
  align-self: center;
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  background: #FFF0CE;
  color: #B26200;
  font-size: 21rpx;
  font-weight: 900;
  margin-bottom: 18rpx;
}

.immersive-line {
  text-align: center;
  color: #172033;
  font-size: 56rpx;
  line-height: 1.28;
  font-weight: 900;
  letter-spacing: 5rpx;
  text-shadow: 0 2rpx 6rpx rgba(255,255,255,0.72), 0 1rpx 0 rgba(255,255,255,0.88);
}

.immersive-dots {
  height: 58rpx;
  display: flex;
  gap: 10rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.immersive-dot {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(255,255,255,0.72);
  background: rgba(15, 23, 42, 0.50);
  border: 1rpx solid rgba(255,255,255,0.13);
}

.immersive-dot.active {
  color: #7A3B00;
  background: linear-gradient(180deg, #FFE38C 0%, #FFB83D 100%);
  transform: scale(1.12);
}

.immersive-dot.done {
  color: #074C2C;
  background: linear-gradient(180deg, #B7F7C5 0%, #4ADE80 100%);
}

.immersive-actions {
  align-self: stretch;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
}

.immersive-primary,
.immersive-secondary {
  width: 100%;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  color: #fff;
  font-weight: 900;
  box-shadow: 0 14rpx 34rpx rgba(0,0,0,0.24);
}

.immersive-primary {
  height: 92rpx;
  line-height: 92rpx;
  font-size: 31rpx;
  background: linear-gradient(180deg, #FFBF57 0%, #FF7A45 100%);
}

.immersive-primary.recording {
  background: linear-gradient(180deg, #FF7474 0%, #E53935 100%);
}

.immersive-primary.playing,
.immersive-primary.preview {
  background: linear-gradient(180deg, #62C2FF 0%, #1E88FF 100%);
}

.immersive-primary.done {
  background: linear-gradient(180deg, #55D983 0%, #16A34A 100%);
}

.immersive-secondary {
  height: 68rpx;
  line-height: 68rpx;
  font-size: 26rpx;
  background: rgba(15, 23, 42, 0.54);
  border: 1rpx solid rgba(255,255,255,0.16);
}

/* 横屏沉浸层最终覆盖：横屏下禁用 rpx 巨型缩放，改 px 控制尺寸 */
.immersive-follow .immersive-head {
  height: 64px;
  padding: 10px 22px 0;
  grid-template-columns: 112px 1fr 96px;
  gap: 14px;
}

.immersive-follow .immersive-back,
.immersive-follow .immersive-count {
  height: 38px;
  line-height: 38px;
  border-radius: 19px;
  font-size: 15px;
}

.immersive-follow .immersive-title {
  font-size: 24px;
  letter-spacing: 2px;
}

.immersive-follow .immersive-author {
  margin-top: 4px;
  font-size: 13px;
}

.immersive-follow .immersive-body {
  height: calc(100vh - 64px);
  padding: 8px 22px 18px;
  grid-template-columns: 174px 1fr 150px;
  gap: 18px;
}

.immersive-follow .immersive-side {
  padding: 18px 14px;
