  letter-spacing: 3px;
}

.immersive-follow .immersive-dots {
  height: 42px;
  gap: 9px;
  margin-top: 18px;
}

.immersive-follow .immersive-dot {
  width: 30px;
  height: 30px;
  line-height: 30px;
  font-size: 13px;
}

.immersive-follow .immersive-actions {
