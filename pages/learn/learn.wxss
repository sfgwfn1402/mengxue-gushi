/* 首次点亮庆祝 */
.celebrate-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
  z-index: 200;
  animation: celebrate-fade 0.25s ease;
}
@keyframes celebrate-fade { from { opacity: 0; } to { opacity: 1; } }
.celebrate-card {
  width: 76%; max-width: 580rpx;
  background: linear-gradient(160deg, #FFFDF5, #FFF1D6);
  border-radius: 36rpx;
  padding: 48rpx 36rpx 36rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.25);
  animation: celebrate-pop 0.4s cubic-bezier(0.18, 0.89, 0.32, 1.28);
}
@keyframes celebrate-pop {
  0% { transform: scale(0.6); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.celebrate-stars { height: 80rpx; position: relative; margin-bottom: 12rpx; }
.celebrate-stars .cs {
  position: absolute; top: 0; font-size: 44rpx;
  animation: cs-rise 0.9s ease both;
}
.cs1 { left: 12%; animation-delay: 0.05s; }
.cs2 { left: 31%; font-size: 32rpx; animation-delay: 0.15s; }
.cs3 { left: 48%; font-size: 56rpx; animation-delay: 0s; }
.cs4 { left: 66%; font-size: 32rpx; animation-delay: 0.2s; }
.cs5 { left: 82%; animation-delay: 0.1s; }
@keyframes cs-rise {
  0% { transform: translateY(30rpx) scale(0.4); opacity: 0; }
  50% { transform: translateY(-10rpx) scale(1.2); opacity: 1; }
  100% { transform: translateY(0) scale(1); opacity: 1; }
}
.celebrate-title { font-size: 38rpx; font-weight: 900; color: #7A3E00; margin-top: 8rpx; }
.celebrate-count { font-size: 28rpx; color: #B5651D; margin-top: 16rpx; }
.celebrate-badge {
  display: inline-block; margin-top: 22rpx;
  font-size: 26rpx; font-weight: 800; color: #fff;
  background: linear-gradient(135deg, #FF9F43, #FF6B6B);
  border-radius: 999rpx; padding: 12rpx 26rpx;
  box-shadow: 0 6rpx 16rpx rgba(255,107,107,0.35);
  animation: badge-pulse 1.2s ease-in-out infinite;
}
@keyframes badge-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}
.celebrate-actions { display: flex; gap: 18rpx; margin-top: 36rpx; }
.celebrate-btn {
  flex: 1; border-radius: 999rpx; padding: 22rpx 0;
  font-size: 28rpx; font-weight: 800;
}
.celebrate-btn.primary { background: linear-gradient(135deg, #FFD36B, #FFB347); color: #7A3E00; }
.celebrate-btn.ghost { background: #fff; color: #8A8F98; border: 2rpx solid #EEE; }

/* AI 朗诵评分结果 */
.score-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 200; animation: celebrate-fade 0.25s ease; }
.score-card { width: 78%; max-width: 600rpx; max-height: 80vh; overflow-y: auto; background: #FFFDF7; border-radius: 36rpx; padding: 44rpx 32rpx 32rpx; text-align: center; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.25); animation: celebrate-pop 0.4s cubic-bezier(0.18,0.89,0.32,1.28); }
.score-ring { width: 180rpx; height: 180rpx; margin: 0 auto; border-radius: 50%; background: linear-gradient(135deg, #FFD36B, #FF8A65); display: flex; align-items: baseline; justify-content: center; box-shadow: 0 10rpx 26rpx rgba(255,138,101,0.35); }
