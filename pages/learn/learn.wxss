}

.immersive-follow .immersive-veil {
  background:
    radial-gradient(circle at 50% 48%, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.01) 32%, rgba(0,0,0,0.36) 72%),
    linear-gradient(90deg, rgba(8,13,25,0.66) 0%, rgba(8,13,25,0.18) 46%, rgba(8,13,25,0.68) 100%);
}

/* Mac 自动预览/竖屏尺寸降级：避免横屏三栏被压成一条竖卡片 */
@media (orientation: portrait) {
  .immersive-follow .immersive-head {
    height: 96px;
    padding: 14px 18px 0;
    grid-template-columns: 86px 1fr 72px;
    gap: 10px;
  }

  .immersive-follow .immersive-back,
  .immersive-follow .immersive-count {
    height: 38px;
