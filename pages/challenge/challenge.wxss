/* pages/challenge/challenge.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 100%);
}

.container {
  padding: 30rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.stats-bar {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.94);
  border-radius: 32rpx;
  padding: 30rpx 22rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.075);
}

.stats-help {
  position: absolute;
  top: 16rpx;
  right: 18rpx;
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 50%;
  background: #FFF3E8;
  color: #FF7A45;
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: 0 6rpx 12rpx rgba(255,122,69,0.12);
}

.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 50rpx; line-height: 1.1; font-weight: 900; color: #FF7A45; display: block; }
.stat-label { font-size: 23rpx; color: #8A8F98; margin-top: 8rpx; display: block; font-weight: 700; }
.stat-divider { width: 1rpx; height: 58rpx; background: #EEF0F5; margin: 0 16rpx; }

.progress-section {
  margin-bottom: 32rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.78);
  box-shadow: 0 10rpx 24rpx rgba(31,35,46,0.045);
}

.progress-label { font-size: 28rpx; color: #1F2937; margin-bottom: 14rpx; font-weight: 900; }
.progress-bar { height: 18rpx; background: #EEF0F5; border-radius: 999rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #FFD66B, #FF7A45); border-radius: 999rpx; transition: width 0.5s; }
.progress-text { font-size: 24rpx; color: #8A8F98; margin-top: 10rpx; font-weight: 700; }

.tasks-title { font-size: 36rpx; font-weight: 900; color: #1F2937; margin-bottom: 22rpx; }
.task-list { display: flex; flex-direction: column; gap: 18rpx; }

.task-card {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.94);
  border-radius: 30rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07);
}

.task-card.completed { opacity: 0.72; }
.task-emoji { width: 74rpx; height: 74rpx; line-height: 74rpx; border-radius: 22rpx; text-align: center; font-size: 44rpx; margin-right: 18rpx; background: #FFF2D2; }
.task-info { flex: 1; min-width: 0; }
.task-name { font-size: 31rpx; font-weight: 900; color: #1F2937; }
.task-desc { font-size: 25rpx; color: #8A8F98; margin-top: 6rpx; }
.task-reward { font-size: 27rpx; color: #FF9500; font-weight: 900; margin: 0 14rpx; }
.task-action { margin-left: auto; }
.task-btn { height: 62rpx; line-height: 62rpx; background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); color: #fff; font-size: 25rpx; font-weight: 900; padding: 0 24rpx; border-radius: 999rpx; border: none; box-shadow: 0 10rpx 18rpx rgba(255,122,69,0.20); }
.task-btn::after { border: none; }
.task-btn:active { transform: scale(0.96); opacity: 0.9; }
.task-done { font-size: 27rpx; color: #45B96C; font-weight: 900; }

.reward-banner {
  text-align: center;
  margin-top: 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFD66B, #FF9F45);
  color: #fff;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 32rpx rgba(255,159,69,0.22);
}
