page { min-height: 100vh; background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 100%); }
.container { padding: 28rpx 24rpx 44rpx; box-sizing: border-box; }
.hero-card { padding: 34rpx; border-radius: 34rpx; background: linear-gradient(145deg, #FFF4E6 0%, #FFD7A8 100%); box-shadow: 0 18rpx 38rpx rgba(255, 149, 0, 0.16); margin-bottom: 24rpx; }
.hero-icon { font-size: 58rpx; margin-bottom: 12rpx; }
.hero-title { font-size: 38rpx; font-weight: 900; color: #1F2937; }
.hero-desc { margin-top: 8rpx; font-size: 26rpx; line-height: 1.6; color: #8A5A18; font-weight: 700; }
.loading { padding: 38rpx; text-align: center; color: #8A8F98; font-weight: 800; }
.admin-grid { display: flex; flex-direction: column; gap: 18rpx; }
.admin-card { display: flex; align-items: center; padding: 28rpx; border-radius: 28rpx; background: rgba(255,255,255,0.96); box-shadow: 0 14rpx 32rpx rgba(31,35,46,0.08); border: 1rpx solid rgba(255,255,255,0.8); }
.admin-card:active { transform: scale(0.985); opacity: 0.9; }
.admin-card.disabled { opacity: 0.55; }
.admin-card-icon { width: 76rpx; height: 76rpx; line-height: 76rpx; text-align: center; border-radius: 24rpx; background: #FFF4E6; font-size: 42rpx; margin-right: 20rpx; }
.admin-card-main { flex: 1; min-width: 0; }
.admin-card-title { font-size: 31rpx; font-weight: 900; color: #1F2937; }
.admin-card-desc { margin-top: 6rpx; font-size: 24rpx; color: #8A8F98; font-weight: 700; }
.admin-card-arrow { font-size: 46rpx; color: #C8CDD6; }
