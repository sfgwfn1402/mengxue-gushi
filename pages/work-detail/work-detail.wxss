.page { min-height: 100vh; background: linear-gradient(180deg,#FFF7D6,#FFFDF5); padding: 24rpx; box-sizing: border-box; }
.empty { margin-top: 160rpx; text-align: center; color: #8A8F98; font-size: 30rpx; font-weight: 800; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.hero { padding: 34rpx 30rpx; border-radius: 32rpx; background: linear-gradient(135deg,#FFD76A,#FF8A65); color: #5B3300; box-shadow: 0 14rpx 30rpx rgba(180,110,0,.16); }
.type-pill { display: inline-block; padding: 10rpx 18rpx; border-radius: 999rpx; background: rgba(255,255,255,.55); font-size: 24rpx; font-weight: 900; }
.poem-title { margin-top: 22rpx; font-size: 48rpx; font-weight: 900; }
.date { margin-top: 10rpx; font-size: 24rpx; opacity: .78; font-weight: 800; }
.content-card { margin-top: 24rpx; padding: 22rpx; border-radius: 32rpx; background: #fff; box-shadow: 0 10rpx 24rpx rgba(120,80,20,.08); }
.artwork { width: 100%; height: 620rpx; border-radius: 26rpx; background: #F3F4F6; }
.audio-box { height: 520rpx; border-radius: 28rpx; background: linear-gradient(180deg,#EEF6FF,#FFFFFF); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.mic { font-size: 120rpx; }
.audio-title { margin-top: 24rpx; font-size: 38rpx; font-weight: 900; color: #1F2937; }
.audio-duration { margin-top: 10rpx; font-size: 26rpx; color: #6B7280; font-weight: 800; }
.play-btn { margin-top: 36rpx; height: 82rpx; line-height: 82rpx; padding: 0 50rpx; border-radius: 999rpx; background: #60A5FA; color: #fff; font-size: 30rpx; font-weight: 900; }
.work-title { margin-top: 24rpx; font-size: 34rpx; font-weight: 900; color: #2F2A1F; text-align: center; }
.desc { margin-top: 12rpx; color: #6B7280; font-size: 26rpx; line-height: 1.55; text-align: center; }
.actions { margin-top: 24rpx; display: flex; justify-content: center; gap: 16rpx; flex-wrap: wrap; }
.compact-actions { align-items: center; }
.action { margin: 0; min-width: 176rpx; height: 62rpx; line-height: 62rpx; padding: 0 30rpx; border-radius: 999rpx; background: #F3F4F6; color: #4B5563; font-size: 25rpx; font-weight: 900; }
.action.primary { background: linear-gradient(180deg,#67B7FF,#3B82F6); color: #fff; box-shadow: 0 8rpx 18rpx rgba(59,130,246,.18); }
.delete-link { margin: 18rpx auto 0; width: 180rpx; text-align: center; color: #C08497; font-size: 23rpx; font-weight: 800; }
.privacy { margin-top: 24rpx; padding: 18rpx 22rpx; border-radius: 22rpx; background: rgba(255,255,255,.82); color: #7C5B21; font-size: 24rpx; line-height: 1.5; }
.share-canvas { position: fixed; left: -9999px; top: -9999px; }
