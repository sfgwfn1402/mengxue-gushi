.container { min-height: 100vh; padding: 28rpx; background: linear-gradient(180deg,#FFF7DF 0%,#FFFDF6 52%,#F7FAFF 100%); box-sizing: border-box; }
.hero-card, .section-card, .history-card { background: rgba(255,255,255,0.94); border-radius: 32rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07); }
.hero-card { text-align: center; }
.hero-icon { font-size: 62rpx; }
.hero-title { margin-top: 10rpx; font-size: 38rpx; font-weight: 900; color: #1F2937; }
.hero-desc { margin-top: 12rpx; font-size: 27rpx; line-height: 1.65; color: #6B7280; }
.field-title { font-size: 30rpx; font-weight: 900; color: #1F2937; margin-bottom: 18rpx; }
.chip-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip { padding: 14rpx 22rpx; border-radius: 999rpx; background: #F3F4F6; color: #4B5563; font-size: 26rpx; font-weight: 800; }
.chip.active { background: linear-gradient(135deg,#FFD66B,#FF8A5C); color: #fff; box-shadow: 0 10rpx 22rpx rgba(255,122,69,0.24); }
.textarea { width: 100%; min-height: 150rpx; box-sizing: border-box; padding: 22rpx; border-radius: 24rpx; background: #F8FAFC; color: #1F2937; font-size: 28rpx; line-height: 1.55; }
.textarea.large { min-height: 210rpx; }
.input { height: 84rpx; padding: 0 22rpx; border-radius: 24rpx; background: #F8FAFC; color: #1F2937; font-size: 28rpx; }
.submit-btn { margin-top: 14rpx; height: 92rpx; line-height: 92rpx; border-radius: 999rpx; background: linear-gradient(135deg,#FF7A45,#FFD166); color: #fff; font-size: 32rpx; font-weight: 900; box-shadow: 0 16rpx 32rpx rgba(255,122,69,0.28); }
.history-title { font-size: 30rpx; font-weight: 900; color: #1F2937; margin-bottom: 16rpx; }
.history-item { padding: 18rpx 0; border-top: 1rpx solid #EEF0F5; }
.history-main { font-size: 26rpx; font-weight: 900; color: #374151; }
.history-desc { margin-top: 8rpx; font-size: 25rpx; color: #6B7280; line-height: 1.5; }
