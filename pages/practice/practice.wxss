/* pages/practice/practice.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 100%);
}

.container { padding: 28rpx 24rpx 44rpx; box-sizing: border-box; }
.header { text-align: center; padding: 26rpx 0 24rpx; }
.title { font-size: 44rpx; font-weight: 900; color: #1F2937; }
.subtitle { font-size: 26rpx; color: #8A8F98; margin-top: 10rpx; font-weight: 600; }
.mode-list { margin-top: 18rpx; }

.mode-card {
  background: rgba(255,255,255,0.94);
  border-radius: 30rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07);
}

.mode-card:active { transform: scale(0.986); opacity: 0.92; }

.mode-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.42), 0 10rpx 18rpx rgba(255,173,50,0.18);
}

.mode-info { flex: 1; min-width: 0; }
.mode-name { font-size: 32rpx; font-weight: 900; color: #1F2937; }
.mode-desc { font-size: 25rpx; color: #8A8F98; margin-top: 8rpx; }
.mode-arrow { font-size: 38rpx; color: #C8CDD6; }

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1F2937;
  margin: 38rpx 0 18rpx;
  padding-left: 0;
  border-left: none;
}

.achievements { display: flex; gap: 16rpx; }
.achievement {
  flex: 1;
  background: rgba(255,255,255,0.94);
  border-radius: 28rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.06);
}
.achievement-icon { font-size: 48rpx; }
.achievement-name { font-size: 23rpx; color: #8A8F98; margin: 10rpx 0; font-weight: 700; }
.achievement-value { font-size: 32rpx; font-weight: 900; color: #FF6B6B; }

/* 练习页模块标题增强 */
.section-title {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx 10rpx;
  border-radius: 999rpx;
  color: #7C2D12;
  background: linear-gradient(180deg, #FFF7ED 0%, #FFEFD5 100%);
  font-weight: 950;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 18rpx rgba(124,45,18,0.08), inset 0 1rpx 0 rgba(255,255,255,0.86);
}

/* 最终回退到初版：取消练习页标题个性化 */
.section-title {
  display: block !important;
  padding: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  color: inherit !important;
  font-weight: 900 !important;
  letter-spacing: 0 !important;
}
