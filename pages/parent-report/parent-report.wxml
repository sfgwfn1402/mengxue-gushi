<!--pages/parent-report/parent-report.wxml-->
<view class="report-container">
  <view wx:if="{{loading}}" class="report-loading">加载中…</view>

  <block wx:else>
    <view class="report-head">
      <view class="report-title">{{nickname}} 的成长周报</view>
      <view class="report-range">{{weekRangeText}}</view>
    </view>

    <!-- 本周亮点 -->
    <view class="report-week-card">
      <view class="report-week-num">{{weekCount}}</view>
      <view class="report-week-label">本周学习/复习了 {{weekCount}} 首古诗</view>
    </view>

    <!-- 累计数据 -->
    <view class="report-stats">
      <view class="report-stat">
        <view class="report-stat-num">{{learnedTotal}}</view>
        <view class="report-stat-label">累计学会</view>
      </view>
      <view class="report-stat">
        <view class="report-stat-num">🔥 {{streak}}</view>
        <view class="report-stat-label">连续学习(天)</view>
      </view>
      <view class="report-stat">
        <view class="report-stat-num">{{totalDays}}</view>
        <view class="report-stat-label">累计学习(天)</view>
      </view>
      <view class="report-stat">
        <view class="report-stat-num">Lv.{{level}}</view>
        <view class="report-stat-label">当前等级</view>
      </view>
    </view>

    <!-- 本周诗单 -->
    <view class="report-section" wx:if="{{weekPoems.length}}">
      <view class="report-section-title">📖 本周学过的诗</view>
      <view class="report-poem" wx:for="{{weekPoems}}" wx:key="id" data-id="{{item.id}}" bindtap="openPoem">
        <text class="report-poem-title">《{{item.title}}》</text>
        <text class="report-poem-author">{{item.author}}</text>
        <text class="report-poem-arrow">›</text>
      </view>
    </view>
    <view class="report-empty" wx:else>本周还没有学习记录，陪孩子读一首古诗吧 🌱</view>

    <button class="report-share" open-type="share">分享给家人 📤</button>
    <view class="report-tip">每天陪孩子读一点，古诗会慢慢长进他的记忆里。</view>
  </block>
</view>
