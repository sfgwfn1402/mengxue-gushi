/* pages/quiz/quiz.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 100%);
}

.container { padding: 30rpx 24rpx 44rpx; box-sizing: border-box; }
.progress-bar { margin-bottom: 28rpx; padding: 22rpx; border-radius: 28rpx; background: rgba(255,255,255,0.78); box-shadow: 0 10rpx 24rpx rgba(31,35,46,0.045); }
.progress-text { text-align: center; font-size: 27rpx; color: #8A8F98; margin-bottom: 12rpx; font-weight: 800; }
.progress-track { height: 14rpx; background: #EEF0F5; border-radius: 999rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #FFD66B, #FF7A45); border-radius: 999rpx; transition: width 0.3s ease; }

.question-card {
  background: rgba(255,255,255,0.95);
  border-radius: 34rpx;
  padding: 38rpx 30rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 18rpx 42rpx rgba(31,35,46,0.085);
  margin-bottom: 28rpx;
  transition: all 0.3s ease;
}
.question-card.correct-anim { animation: pulse 0.5s ease; box-shadow: 0 0 32rpx rgba(69, 185, 108, 0.28); }
.question-card.wrong-anim { animation: shake 0.5s ease; }
.question-type { display: inline-flex; padding: 8rpx 18rpx; border-radius: 999rpx; background: #FFF0D0; color: #B86B00; font-size: 24rpx; font-weight: 900; margin-bottom: 30rpx; }
.question-text { text-align: center; }
.poem-line { font-size: 38rpx; line-height: 1.65; color: #1F2937; display: block; margin-bottom: 34rpx; font-weight: 800; }
.hint { font-size: 27rpx; color: #8A8F98; margin-bottom: 18rpx; }
.hint-content { font-size: 32rpx; color: #1F2937; font-weight: 900; margin-bottom: 36rpx; padding: 22rpx; background: #FFF5DE; border-radius: 22rpx; }
.option-list { display: flex; flex-direction: column; gap: 18rpx; margin-top: 28rpx; }
.option-card { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 24rpx; border-radius: 24rpx; background: #F8FAFF; border: 3rpx solid transparent; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); transition: all 0.2s ease; }
.option-card:active { transform: scale(0.98); }
.option-dot { width: 46rpx; height: 46rpx; line-height: 46rpx; text-align: center; border-radius: 50%; background: #FFF0D0; color: #B86B00; font-size: 25rpx; font-weight: 900; }
.option-text { flex: 1; font-size: 34rpx; color: #1F2937; font-weight: 900; }
.option-correct, .option-answer { border-color: #45B96C; background: #F0FFF4; }
.option-wrong { border-color: #E84A5F; background: #FFF1F3; }
.option-correct .option-dot, .option-answer .option-dot { background: #45B96C; color: #fff; }
.option-wrong .option-dot { background: #E84A5F; color: #fff; }
.hint-btn { text-align: center; color: #FF9500; font-size: 28rpx; padding: 20rpx; font-weight: 800; }
.hint-box { background: #FFF5DE; border-radius: 22rpx; padding: 22rpx; text-align: center; color: #B86B00; font-size: 28rpx; margin-bottom: 28rpx; font-weight: 700; }
.actions { margin-top: 28rpx; }
.btn { height: 86rpx; line-height: 86rpx; border-radius: 999rpx; font-size: 31rpx; font-weight: 900; padding: 0; border: none; }
.btn-primary { background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); color: #fff; box-shadow: 0 12rpx 24rpx rgba(255,122,69,0.22); }
.btn-secondary { background: rgba(255,255,255,0.94); color: #FF7A45; border: 1rpx solid rgba(255,122,69,0.18); margin-top: 18rpx; box-shadow: 0 10rpx 22rpx rgba(31,35,46,0.06); }
.result { text-align: center; margin-top: 28rpx; font-size: 32rpx; font-weight: 900; }
.correct { color: #45B96C; }
.wrong { color: #E84A5F; }
.answer-explain { margin-top: 14rpx; padding: 18rpx 22rpx; border-radius: 20rpx; background: #FFF5DE; color: #9A5B00; font-size: 25rpx; line-height: 1.55; font-weight: 700; }
.empty { text-align: center; padding: 120rpx 30rpx; color: #8A8F98; }
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; font-weight: 800; }
.complete { text-align: center; padding: 56rpx 20rpx; }
.complete-icon { font-size: 116rpx; }
.complete-title { font-size: 48rpx; font-weight: 900; color: #1F2937; margin: 20rpx 0; }
.complete-score { font-size: 36rpx; color: #FF6B6B; margin-bottom: 20rpx; font-weight: 900; }
.complete-message { font-size: 28rpx; color: #8A8F98; margin-bottom: 38rpx; }
.complete-btns { display: flex; flex-direction: column; gap: 18rpx; }
