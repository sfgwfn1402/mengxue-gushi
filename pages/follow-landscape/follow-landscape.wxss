page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #111827;
}

.landscape-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  color: #fff;
}

.bg,
.fallback-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.fallback-bg {
  background: radial-gradient(circle at 25% 30%, #FFE2A8 0%, transparent 32%), linear-gradient(135deg, #243B53 0%, #0F172A 62%, #381D1D 100%);
}

.veil {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 48%, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.02) 28%, rgba(0,0,0,0.48) 72%),
    linear-gradient(90deg, rgba(8,13,25,0.76) 0%, rgba(8,13,25,0.26) 46%, rgba(8,13,25,0.78) 100%);
}

.header {
  position: relative;
  z-index: 2;
  height: 64px;
  padding: 10px 22px 0;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 112px 1fr 96px;
  align-items: center;
  gap: 14px;
}

.back-btn,
.step-pill {
  height: 38px;
  line-height: 38px;
  border-radius: 19px;
  background: rgba(15, 23, 42, 0.48);
  border: 1px solid rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.92);
  font-size: 15px;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 8px 24px rgba(0,0,0,0.18);
}

.title-box {
  min-width: 0;
  text-align: center;
  text-shadow: 0 3px 12px rgba(0,0,0,0.46);
}

.title {
  font-size: 24px;
  line-height: 1.1;
  font-weight: 900;
  letter-spacing: 2px;
  color: #FFF2C2;
}

.author {
  margin-top: 4px;
  font-size: 13px;
  color: rgba(255,255,255,0.74);
  font-weight: 600;
}

.content {
  position: relative;
  z-index: 2;
  height: calc(100vh - 64px);
  padding: 8px 22px 18px;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 174px 1fr 150px;
  gap: 18px;
  align-items: center;
}

.left-panel {
  align-self: stretch;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 18px 14px;
  box-sizing: border-box;
  border-radius: 26px;
  background: rgba(15, 23, 42, 0.34);
  border: 1px solid rgba(255,255,255,0.14);
  backdrop-filter: blur(8px);
}

.mode-label {
  width: fit-content;
  padding: 6px 11px;
  border-radius: 999px;
  background: rgba(255, 213, 111, 0.18);
  color: #FFE2A8;
  font-size: 12px;
  font-weight: 800;
}

.phase-text {
  margin-top: 18px;
  font-size: 25px;
  line-height: 1.2;
  font-weight: 900;
  color: #fff;
}

.phase-text.playing { color: #A7D8FF; }
.phase-text.recording { color: #FFB4B4; }
.phase-text.preview { color: #CDBBFF; }
.phase-text.done { color: #A7F3D0; }

.hint {
  margin-top: 14px;
  font-size: 13px;
  line-height: 1.65;
  color: rgba(255,255,255,0.70);
}

.center-panel {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.line-card {
  width: 100%;
  max-width: 650px;
  min-height: 168px;
  padding: 24px 30px 28px;
  box-sizing: border-box;
  border-radius: 34px;
  background: transparent;
  border: 1px solid transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.line-index {
  align-self: center;
  padding: 4px 12px;
  border-radius: 999px;
  background: #FFF0CE;
  color: #B26200;
  font-size: 12px;
  font-weight: 900;
  margin-bottom: 12px;
}

.line-text {
  text-align: center;
  color: #172033;
  font-size: 42px;
  line-height: 1.28;
  font-weight: 900;
  letter-spacing: 3px;
  word-break: keep-all;
}

.dots {
  height: 42px;
  display: flex;
  gap: 9px;
  margin-top: 18px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.dot-item {
  width: 30px;
  height: 30px;
  line-height: 30px;
  text-align: center;
  border-radius: 50%;
  font-size: 13px;
  font-weight: 900;
  color: rgba(255,255,255,0.72);
  background: rgba(15, 23, 42, 0.48);
  border: 1px solid rgba(255,255,255,0.13);
}

.dot-item.active {
  color: #7A3B00;
  background: linear-gradient(180deg, #FFE38C 0%, #FFB83D 100%);
  border-color: rgba(255,255,255,0.4);
  transform: scale(1.13);
}

.dot-item.done {
  color: #074C2C;
  background: linear-gradient(180deg, #B7F7C5 0%, #4ADE80 100%);
}

.right-panel {
  align-self: stretch;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 14px;
}

button {
  border: 0;
  margin: 0;
  padding: 0;
}

.main-btn,
.side-btn {
  width: 100%;
  border-radius: 999px;
  color: #fff;
  font-weight: 900;
  box-shadow: 0 12px 30px rgba(0,0,0,0.24);
}

.main-btn {
  height: 76px;
  line-height: 76px;
  font-size: 24px;
  background: linear-gradient(180deg, #FFBF57 0%, #FF7A45 100%);
}

.main-btn.recording {
  background: linear-gradient(180deg, #FF7474 0%, #E53935 100%);
}

.main-btn.playing,
.main-btn.preview {
  background: linear-gradient(180deg, #62C2FF 0%, #1E88FF 100%);
}

.main-btn.done {
  background: linear-gradient(180deg, #55D983 0%, #16A34A 100%);
}

.side-btn {
  height: 54px;
  line-height: 54px;
  font-size: 18px;
  background: rgba(15, 23, 42, 0.52);
  border: 1px solid rgba(255,255,255,0.16);
}

.main-btn:active,
.side-btn:active,
.back-btn:active,
.dot-item:active {
  transform: scale(0.97);
  opacity: 0.92;
}

@media (max-height: 360px) {
  .header { height: 56px; padding-top: 8px; }
  .content { height: calc(100vh - 56px); grid-template-columns: 154px 1fr 132px; gap: 12px; padding-bottom: 12px; }
  .line-card { min-height: 138px; padding: 18px 22px 20px; border-radius: 28px; }
  .line-text { font-size: 34px; }
  .main-btn { height: 64px; line-height: 64px; font-size: 21px; }
  .side-btn { height: 46px; line-height: 46px; font-size: 16px; }
  .phase-text { font-size: 21px; }
}
