<!--pages/index/index.wxml-->
<view class="container">
  <view class="home-tabs">
    <view class="home-tab {{homeTab === 'learn' ? 'active' : ''}}" data-tab="learn" bindtap="switchHomeTab">诗旅</view>
    <view class="home-tab {{homeTab === 'discover' ? 'active' : ''}}" data-tab="discover" bindtap="switchHomeTab">发现</view>
    <view class="home-tab {{homeTab === 'plaza' ? 'active' : ''}}" data-tab="plaza" bindtap="switchHomeTab">社区</view>
  </view>

  <block wx:if="{{homeTab === 'learn'}}">
  <view class="community-bar" wx:if="{{showCommunity}}">
    <text class="community-dot">📖</text>
    <text class="community-text">已有 <text class="community-num">{{communityLearners}}</text> 位小朋友在学 · {{communitySubText}}</text>
  </view>

  <view class="onboard-card {{onboardExpanded ? 'open' : 'collapsed'}}" wx:if="{{!onboardAllDone}}">
    <view class="onboard-head" bindtap="toggleOnboard">
      <view class="onboard-head-left">
        <view class="onboard-title">🎓 新手引导 {{onboardDoneCount}}/{{onboardTotal}}</view>
        <view class="onboard-subtitle">{{onboardExpanded ? '跟着做一遍，就会用啦' : '点开看看怎么玩'}}</view>
      </view>
      <view class="onboard-toggle">{{onboardExpanded ? '收起 ⌃' : '展开 ⌄'}}</view>
    </view>
    <block wx:if="{{onboardExpanded}}">
      <view class="onboard-step {{item.done ? 'done' : ''}}" wx:for="{{onboardSteps}}" wx:key="key" data-target="{{item.target}}" bindtap="tapOnboardStep">
        <view class="onboard-check">{{item.done ? '✅' : item.index}}</view>
        <view class="onboard-step-main">
          <view class="onboard-step-label">{{item.label}}</view>
          <view class="onboard-step-desc">{{item.desc}}</view>
        </view>
        <view class="onboard-step-arrow" wx:if="{{!item.done}}">去做 →</view>
      </view>
    </block>
  </view>

  <!-- 学习状态悬浮球：点开看 连续/复习/上次成长 -->
  <view class="study-ball {{ballHover ? 'hover' : ''}}" style="left: {{ballX}}px; top: {{ballY}}px;"
        bindmouseenter="onBallHover" bindmouseleave="onBallLeave"
        catchtouchstart="onBallTouchStart" catchtouchmove="onBallTouchMove" catchtouchend="onBallTouchEnd">
    <view class="study-ball-gloss"></view>
    <text class="study-ball-icon">🔥</text>
    <text class="study-ball-num">{{streak}}</text>
    <view class="study-ball-dot" wx:if="{{reviewDueCount > 0 || !todayChecked}}"></view>
  </view>

  <view class="study-mask" wx:if="{{studyPanelOpen}}" bindtap="closeStudyPanel">
    <view class="study-panel" catchtap="noop">
      <view class="study-panel-title">我的小书房</view>

      <view class="streak-banner {{todayChecked ? 'done' : 'todo'}}" bindtap="goChallenge">
        <view class="streak-flame">🔥</view>
        <view class="streak-main">
          <view class="streak-num">已经坚持 <text class="streak-days">{{streak}}</text> 天</view>
          <view class="streak-sub">{{streakSub}}</view>
        </view>
        <view class="streak-cta">{{todayChecked ? '今天读过啦 ✓' : '去读一首 →'}}</view>
      </view>

      <!-- 今日学习计划：1首新诗 + 到期复习 -->
      <view class="plan-card" wx:if="{{dailyPlan && !dailyPlan.empty}}">
        <view class="plan-head">
          <view class="plan-title">📖 今天读什么</view>
          <view class="plan-progress">{{dailyPlan.doneCount}}/{{dailyPlan.total}}</view>
        </view>
        <view class="plan-bar"><view class="plan-bar-fill" style="width: {{dailyPlan.doneCount / dailyPlan.total * 100}}%"></view></view>
        <view class="plan-item {{item.done ? 'done' : ''}}" wx:for="{{dailyPlan.items}}" wx:key="id" data-id="{{item.id}}" data-kind="{{item.kind}}" catchtap="goPlanItem">
          <view class="plan-check">{{item.done ? '✅' : (item.kind === 'new' ? '🌱' : '🔁')}}</view>
          <view class="plan-item-main">
            <view class="plan-item-title">{{item.kind === 'new' ? '读新诗' : '再读'}}《{{item.title}}》</view>
            <view class="plan-item-sub">{{item.sub}}</view>
          </view>
          <view class="plan-item-cta" wx:if="{{!item.done}}">{{item.kind === 'new' ? '去读 →' : '再读读 →'}}</view>
          <view class="plan-item-cta done-tag" wx:else>读过啦</view>
        </view>
        <view wx:if="{{dailyPlan.allDone}}" class="plan-alldone">🎉 今天的诗都读完啦，真棒！</view>
      </view>
      <view wx:elif="{{dailyPlan && dailyPlan.empty}}" class="plan-card plan-empty">
        <view class="plan-empty-emoji">🌟</view>
        <view class="plan-empty-text">今天的诗读完啦～挑一首喜欢的再读读吧</view>
      </view>

      <view class="panel-listen" bindtap="goListen">
        <view class="panel-listen-icon">🎧</view>
        <view class="panel-listen-main">
          <view class="panel-listen-title">磨耳朵 · 放着听</view>
          <view class="panel-listen-sub">睡前、路上不知不觉就会了</view>
        </view>
        <view class="panel-listen-go">去听 →</view>
      </view>

      <view class="invite-banner">
        <view class="invite-banner-icon">🎁</view>
        <view class="invite-banner-main">
          <view class="invite-banner-title">叫上小伙伴一起读</view>
          <view class="invite-banner-sub">{{inviteCount > 0 ? '已经叫来 ' + inviteCount + ' 位 · 有勋章' : '小伙伴来了就有勋章'}}</view>
        </view>
        <button class="invite-banner-cta" open-type="share">去邀请 →</button>
      </view>

    </view>
  </view>

  <view class="maintenance" wx:if="{{!todayPoem}}">
    <view class="maintenance-title">{{backendError ? '服务维护中' : '古诗加载中'}}</view>
    <view class="maintenance-desc">{{backendError || '正在准备今日古诗，请稍等一下～'}}</view>
  </view>

  <block wx:if="{{todayPoem}}">
    <view class="today-card" wx:if="{{todayPoem}}" bindtap="goToLearn" data-id="{{todayPoem.id}}" data-type="poem">
      <image wx:if="{{todayPoem.imageUrl}}" class="today-image" src="{{todayPoem.imageUrl}}" mode="aspectFill"></image>
      <view class="today-label">📚 今日一诗</view>
      <view class="today-title">{{todayPoem.title}}</view>
      <view class="today-author">{{todayPoem.dynasty}} · {{todayPoem.author}}</view>
      <view class="today-lines">{{todayPoem.content}}</view>
      <view class="today-bottom">
        <view class="today-tags" wx:if="{{todayPoem.displayThemes && todayPoem.displayThemes.length}}">
          <text wx:for="{{todayPoem.displayThemes}}" wx:for-item="theme" wx:key="id">{{theme.emoji}} {{theme.name}}</text>
        </view>
        <view class="today-btn">开始学习 ›</view>
      </view>
    </view>

    <!-- 磨耳朵入口 -->
    <view class="listen-entry" bindtap="goListen">
      <view class="listen-entry-icon">🎧</view>
      <view class="listen-entry-main">
        <view class="listen-entry-title">磨耳朵 · 古诗听单</view>
        <view class="listen-entry-sub">睡前、路上放着听，不知不觉就会了</view>
      </view>
      <view class="listen-entry-go">去听 →</view>
    </view>

    <!-- 诗词故事会入口 -->
    <view class="story-entry" bindtap="goStory">
      <view class="story-entry-icon">📖</view>
      <view class="story-entry-main">
        <view class="story-entry-title">诗词故事会</view>
        <view class="story-entry-sub">每首诗背后都有个小故事，听一听更好懂</view>
      </view>
      <view class="story-entry-go">去看 →</view>
    </view>

    <!-- 诗词游戏入口 -->
    <view class="game-entry" bindtap="goGame">
      <view class="game-entry-icon">🎮</view>
      <view class="game-entry-main">
        <view class="game-entry-title">诗词游戏</view>
        <view class="game-entry-sub">飞花令、诗句配对，边玩边记牢</view>
      </view>
      <view class="game-entry-go">去玩 →</view>
    </view>

    <!-- 古诗卡册入口 -->
    <view class="cards-entry" bindtap="goCards">
      <view class="cards-entry-icon">🃏</view>
      <view class="cards-entry-main">
        <view class="cards-entry-title">古诗卡册</view>
        <view class="cards-entry-sub">学一首点亮一张收藏卡，集齐它们</view>
      </view>
      <view class="cards-entry-go">去集卡 →</view>
    </view>

    <!-- 朗诵秀：人气朗诵 + 本周排行 双Tab切换 -->
    <view class="recitation-show">
      <view class="show-tabs">
        <view class="show-tab {{recitationShowTab === 'hot' ? 'active' : ''}}" bindtap="switchRecitationShowTab" data-tab="hot">
          <text>🎙️ 古诗人气朗诵</text>
          <view class="tab-underline" wx:if="{{recitationShowTab === 'hot'}}"></view>
        </view>
        <view class="show-tab {{recitationShowTab === 'rank' ? 'active' : ''}}" bindtap="switchRecitationShowTab" data-tab="rank">
          <text>🏆 本周朗诵排行</text>
          <view class="tab-underline" wx:if="{{recitationShowTab === 'rank'}}"></view>
        </view>
      </view>
      <!-- 人气朗诵 -->
      <block wx:if="{{recitationShowTab === 'hot' && todayRecitationPages.length}}">
        <swiper class="carousel-swiper" autoplay interval="5000" circular indicator-dots="{{false}}" current="{{carouselIndex}}" bindchange="onCarouselChange">
          <swiper-item wx:for="{{todayRecitationPages}}" wx:key="page">
            <view class="carousel-page">
              <view class="carousel-item {{loopIndex0 === 0 ? 'item-coral' : 'item-sky'}}" wx:for="{{item}}" wx:key="recitation.id" wx:for-item="rec" wx:for-index="loopIndex0">
                <view class="carousel-rank">
                  <text class="carousel-rank-num">{{loopIndex0 + 1}}</text>
                </view>
                <view class="carousel-poem-col">
                  <view class="carousel-poem-title">《{{rec.poem_title}}》</view>
                  <view class="carousel-poem-sub">{{rec.poem_dynasty || ''}}{{rec.poem_author ? ' · ' + rec.poem_author : ''}}</view>
                </view>
                <view class="carousel-user-col">
                  <view class="carousel-user-name">{{rec.recitation.nickname || '小诗童'}}</view>
                  <view class="carousel-user-likes">❤ {{rec.recitation.like_count}}</view>
                </view>
                <view class="carousel-play-wrap">
                  <view class="carousel-play-btn {{playingRecitationId === rec.recitation.id ? 'playing' : ''}}" catchtap="playCarouselRecitation" data-id="{{rec.recitation.id}}">
                    <text>{{playingRecitationId === rec.recitation.id ? '■' : '▶'}}</text>
                  </view>
                </view>
              </view>
            </view>
          </swiper-item>
        </swiper>
        <view class="carousel-dots">
          <view class="carousel-dot {{carouselIndex === index ? 'active' : ''}}" wx:for="{{todayRecitationPages}}" wx:key="page" wx:for-index="index"></view>
        </view>
      </block>
      <!-- 本周排行 -->
      <block wx:if="{{recitationShowTab === 'rank' && weeklyRankPages.length}}">
        <swiper class="carousel-swiper" autoplay interval="5000" circular indicator-dots="{{false}}" current="{{weeklyRankIndex}}" bindchange="onWeeklyRankChange">
          <swiper-item wx:for="{{weeklyRankPages}}" wx:key="page">
            <view class="carousel-page">
              <view class="carousel-item {{loopIndex0 === 0 ? 'item-coral' : 'item-sky'}}" wx:for="{{item}}" wx:key="recitation.id" wx:for-item="rec" wx:for-index="loopIndex0">
                <view class="carousel-rank">
                  <text class="carousel-rank-num">{{rec._rankIndex}}</text>
                </view>
                <view class="carousel-poem-col">
                  <view class="carousel-poem-title">《{{rec.poem_title}}》</view>
                  <view class="carousel-poem-sub">{{rec.poem_dynasty || ''}}{{rec.poem_author ? ' · ' + rec.poem_author : ''}}</view>
                </view>
                <view class="carousel-user-col">
                  <view class="carousel-user-name">{{rec.recitation.nickname || '小诗童'}}</view>
                  <view class="carousel-user-likes">❤ {{rec.recitation.like_count}}</view>
                </view>
                <view class="carousel-play-wrap">
                  <view class="carousel-play-btn {{playingRecitationId === rec.recitation.id ? 'playing' : ''}}" catchtap="playCarouselRecitation" data-id="{{rec.recitation.id}}">
                    <text>{{playingRecitationId === rec.recitation.id ? '■' : '▶'}}</text>
                  </view>
                </view>
              </view>
            </view>
          </swiper-item>
        </swiper>
        <view class="carousel-dots">
          <view class="carousel-dot {{weeklyRankIndex === index ? 'active' : ''}}" wx:for="{{weeklyRankPages}}" wx:key="page" wx:for-index="index"></view>
        </view>
      </block>
      <view class="show-empty" wx:if="{{recitationShowTab === 'rank' && !weeklyRankPages.length}}">本周还没有朗诵，快去创作第一个吧～</view>
    </view>

    <view class="section-title row-title">
      <text>🚀 今天怎么学</text>
      <text class="more" bindtap="openWarehouse">更多诗 ›</text>
    </view>
    <view class="learning-path-grid">
      <view class="learning-path-card path-{{index % 4}}" wx:for="{{learningPaths}}" wx:key="id" bindtap="tapLearnEntry" data-action="{{item.action}}" data-keyword="{{item.keyword}}" data-category="{{item.category}}" data-mode="{{item.mode}}">
        <view class="path-emoji">{{item.emoji}}</view>
        <view class="path-title">{{item.title}}</view>
        <view class="path-desc">{{item.desc}}</view>
      </view>
    </view>

    <view class="section-title row-title">
      <text>✨ 为你推荐</text>
      <text class="more">{{recommendShortReason}}</text>
    </view>
    <view class="recommend-list">
      <view class="recommend-card" wx:for="{{recommendedPoems}}" wx:key="id" bindtap="goToLearn" data-id="{{item.id}}" data-type="poem">
        <image wx:if="{{item.imageUrl}}" class="recommend-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view class="poem-primary-theme" wx:if="{{item.primaryTheme}}">{{item.primaryTheme.emoji}} {{item.primaryTheme.name}}</view>
        <view class="recommend-title">{{item.title}}</view>
        <view class="recommend-author">{{item.dynasty}} · {{item.author}}</view>
      </view>
    </view>

    <view class="section-title row-title">
      <text>🔎 按孩子能懂的主题找</text>
      <text class="more" bindtap="openWarehouse">诗园 ›</text>
    </view>
    <view class="child-theme-grid">
      <view class="child-theme theme-{{index % 8}}" wx:for="{{childThemes}}" wx:key="name" bindtap="openThemeKeyword" data-keyword="{{item.keyword}}" data-name="{{item.name}}">
        <view class="child-theme-emoji">{{item.emoji}}</view>
        <view class="child-theme-name">{{item.name}}</view>
      </view>
    </view>

  </block>
  </block>

  <block wx:if="{{homeTab === 'discover'}}">
    <view class="discover-header">
      <view class="discover-title">大家的古诗作品</view>
      <view class="discover-sub">看看小诗童们的朗诵和诗配画</view>
    </view>
    <view class="discover-filters">
      <view class="discover-filter {{discoverFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="switchDiscoverFilter">全部</view>
      <view class="discover-filter {{discoverFilter === 'artwork' ? 'active' : ''}}" data-filter="artwork" bindtap="switchDiscoverFilter">诗配画</view>
      <view class="discover-filter {{discoverFilter === 'recitation' ? 'active' : ''}}" data-filter="recitation" bindtap="switchDiscoverFilter">朗诵</view>
    </view>
    <view class="discover-waterfall" wx:if="{{visibleDiscoverItems.length}}">
      <view class="discover-card {{item.type}}" wx:for="{{visibleDiscoverItems}}" wx:key="id">
        <image wx:if="{{item.type === 'artwork'}}" class="discover-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view wx:else class="recitation-cover tone-{{item.coverTone}}" data-id="{{item.id}}" bindtap="playDiscoverRecitation">
          <image wx:if="{{item.poemImageUrl && !failedCovers[item.id]}}" class="recitation-cover-bg" src="{{item.poemImageUrl}}" mode="aspectFill" data-id="{{item.id}}" binderror="onRecitationCoverError"></image>
          <view wx:else class="recitation-cover-mic">🎙️</view>
          <view class="recitation-cover-shade"></view>
          <view class="recitation-play-btn {{playingRecitationId === item.id ? 'playing' : ''}}">
            <view wx:if="{{playingRecitationId === item.id}}" class="eq"><view class="eq-bar"></view><view class="eq-bar"></view><view class="eq-bar"></view></view>
            <text wx:else class="play-tri">▶</text>
          </view>
          <view class="recitation-cover-foot">
            <text class="recitation-cover-title">《{{item.poemTitle}}》</text>
            <text wx:if="{{item.durationText}}" class="recitation-cover-dur">{{item.durationText}}</text>
          </view>
        </view>
        <view class="discover-card-body">
          <view class="discover-card-title">{{item.title}}</view>
          <view class="discover-card-poem" wx:if="{{item.type === 'artwork'}}">《{{item.poemTitle}}》</view>
          <view class="discover-user-row">
            <image wx:if="{{item.avatarUrl}}" class="discover-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="discover-avatar fallback">👶</view>
            <view class="discover-nickname">{{item.nickname}}</view>
            <view class="discover-like {{item.likedByMe ? 'liked' : ''}}" data-id="{{item.id}}" data-type="{{item.type}}" catchtap="toggleDiscoverLike">{{item.likedByMe ? '♥' : '♡'}} {{item.likeCount}}</view>
          </view>
        </view>
      </view>
    </view>
    <view class="discover-empty" wx:else>还没有作品，去“创作”发布第一条吧～</view>
  </block>

  <!-- 社区 -->
  <block wx:if="{{homeTab === 'plaza'}}">
    <view class="plaza-head">
      <view class="plaza-title">💬 社区</view>
      <view class="plaza-sub">看看大家的分享，也来发一条吧</view>
    </view>

    <view wx:if="{{!momentItems.length && momentsLoaded}}" class="plaza-empty">
      <view class="plaza-empty-emoji">🌱</view>
      <view class="plaza-empty-text">还没有人发动态，来发第一条吧～</view>
    </view>

    <view class="moment" wx:for="{{momentItems}}" wx:key="id">
      <view class="moment-top">
        <image wx:if="{{item.avatar_url}}" class="moment-avatar" src="{{item.avatar_url}}" mode="aspectFill"></image>
        <view wx:else class="moment-avatar fallback">👶</view>
        <view class="moment-meta">
          <view class="moment-name">{{item.nickname || '小诗童家长'}}<text wx:if="{{item.status === 'submitted'}}" class="moment-pending">审核中</text></view>
          <view class="moment-time">{{item.timeText}}</view>
        </view>
      </view>
      <view wx:if="{{item.content}}" class="moment-content">{{item.content}}</view>
      <view class="moment-grid grid-{{item.images.length > 4 ? 3 : (item.images.length === 1 ? 1 : (item.images.length === 4 ? 2 : (item.images.length < 3 ? item.images.length : 3)))}}">
        <image class="moment-grid-img" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
          src="{{img}}" mode="aspectFill" data-urls="{{item.images}}" data-cur="{{img}}" catchtap="previewMoment"></image>
      </view>
      <view class="moment-actions">
        <view class="moment-like {{item.liked_by_me ? 'liked' : ''}}" data-id="{{item.id}}" catchtap="toggleMomentLike">
          {{item.liked_by_me ? '♥' : '♡'}} {{item.like_count || 0}}
        </view>
      </view>
    </view>

    <view wx:if="{{momentsLoading}}" class="plaza-loading">加载中…</view>

    <view class="plaza-fab" bindtap="goPostMoment">＋ 发一条</view>
  </block>

  <!-- 首次欢迎引导 -->
  <view class="welcome-mask" wx:if="{{showWelcome}}">
    <view class="welcome-card">
      <swiper class="welcome-swiper" indicator-dots="true" indicator-active-color="#FF8A65" circular="false">
        <swiper-item>
          <view class="welcome-emoji">📖</view>
          <view class="welcome-h">欢迎来到萌学古诗</view>
          <view class="welcome-p">陪孩子每天读一点古诗，多听、多读、多探索，慢慢爱上古诗。</view>
        </swiper-item>
        <swiper-item>
          <view class="welcome-emoji">🎙️</view>
          <view class="welcome-h">听 → 学 → 背 → 复习</view>
          <view class="welcome-p">先听官方朗读，逐句跟读，再背诵闯关；学过的诗会定时提醒复习，记得更牢。</view>
        </swiper-item>
        <swiper-item>
          <view class="welcome-emoji">⭐</view>
          <view class="welcome-h">看孩子点亮的诗集</view>
          <view class="welcome-p">每学会一首就点亮一颗星，还能录朗诵、AI 评分、生成成长卡分享给家人。</view>
        </swiper-item>
      </swiper>
      <view class="welcome-btn" bindtap="dismissWelcome">开始体验</view>
    </view>
  </view>

  <view class="invite-welcome-mask" wx:if="{{inviteWelcomeVisible}}" catchtap="dismissInviteWelcome">
    <view class="invite-welcome-card" catchtap="noop">
      <view class="invite-welcome-emoji">🎁</view>
      <view class="invite-welcome-title">{{inviteWelcomeText}}</view>
      <view class="invite-welcome-sub">这里有 160+ 首古诗，听读背全都有，还能录朗诵、得勋章～</view>
      <view class="invite-welcome-btn" bindtap="startFromInvite">开始学第一首 →</view>
      <view class="invite-welcome-skip" bindtap="dismissInviteWelcome">先逛逛</view>
    </view>
  </view>
</view>
