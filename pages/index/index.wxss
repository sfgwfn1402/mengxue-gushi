/* pages/index/index.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: #FFF2DE;
  color: #1D1D1F;
}

.container {
  padding: 28rpx 24rpx 44rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 62%, #FFF2DE 100%);
}

.header {
  text-align: center;
  padding: 28rpx 0 20rpx;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  line-height: 132rpx;
  margin: 0 auto 18rpx;
  border-radius: 34rpx;
  font-size: 82rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 18rpx 38rpx rgba(31,35,46,0.09), inset 0 1rpx 0 rgba(255,255,255,0.9);
}

.title {
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #1F2937;
  letter-spacing: 2rpx;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #8A8F98;
}

.source-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(31,35,46,0.08);
}

.source-badge.online { background: linear-gradient(180deg, #6DD98A 0%, #45B96C 100%); }
.source-badge.offline { background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); }

.source-error {
  margin: 14rpx auto 0;
  max-width: 640rpx;
  color: #C2410C;
  background: rgba(255, 237, 213, 0.92);
  border-radius: 18rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  word-break: break-all;
}

.maintenance,
.banner,
.poem-card,
.idiom-card,
.stats-card,
.level-card {
  background: rgba(255,255,255,0.94);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.075), 0 2rpx 8rpx rgba(31,35,46,0.04);
}

.maintenance {
  padding: 60rpx 30rpx;
  margin: 28rpx 0;
  text-align: center;
}

.maintenance-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #FF7A45;
}

.maintenance-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #8A8F98;
}

.banner {
  position: relative;
  overflow: hidden;
  padding: 38rpx;
  margin: 28rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #FFD66B 0%, #FF9F45 100%);
  box-shadow: 0 18rpx 38rpx rgba(255, 159, 69, 0.22), inset 0 1rpx 0 rgba(255,255,255,0.35);
}

.banner::after {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -80rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.22);
}

.banner-text {
  position: relative;
  font-size: 36rpx;
  color: #fff;
  font-weight: 900;
}

.banner-desc {
  position: relative;
  font-size: 26rpx;
  color: rgba(255,255,255,0.92);
  margin-top: 10rpx;
  font-weight: 700;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1F2937;
  margin: 34rpx 0 18rpx;
  padding-left: 0;
  border-left: none;
}

.poem-card,
.idiom-card {
  padding: 28rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
}

.poem-card:active,
.idiom-card:active,
.level-card:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.poem-icon {
  width: 94rpx;
  height: 94rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.40), 0 10rpx 18rpx rgba(255,173,50,0.20);
}

.poem-icon.blue {
  background: linear-gradient(180deg, #71B8FF 0%, #3D8CFF 100%);
}

.poem-info { flex: 1; min-width: 0; }

.poem-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1F2937;
}

.poem-author {
  font-size: 25rpx;
  color: #8A8F98;
  margin-top: 8rpx;
}

.difficulty { display: flex; gap: 6rpx; }
.star { font-size: 24rpx; color: #D9DDE5; }
.star.active { color: #FFBE32; }
.poem-arrow { font-size: 34rpx; color: #C8CDD6; }

.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #8A8F98;
  font-size: 24rpx;
  font-weight: 700;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 900;
  color: #FF6B6B;
}

.level-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.level-card {
  padding: 26rpx 10rpx;
  text-align: center;
}

.level-emoji { font-size: 44rpx; }
.level-name { font-size: 29rpx; font-weight: 900; color: #1F2937; margin-top: 8rpx; }
.level-count { font-size: 23rpx; color: #8A8F98; margin-top: 6rpx; }

.poem-theme-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 10rpx 0 2rpx;
}

.poem-theme-tag {
  max-width: 176rpx;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #FFF4D8;
  color: #9A6A2E;
  font-size: 21rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poem-primary-theme {
  display: inline-flex;
  align-items: center;
  max-width: 220rpx;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 14rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #FFF4D8 0%, #FFE4A8 100%);
  color: #9A5B00;
  font-size: 21rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 34rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07);
}
.hello-title { font-size: 38rpx; font-weight: 900; color: #1F2937; }
.hello-subtitle { margin-top: 8rpx; font-size: 25rpx; color: #8A8F98; font-weight: 700; }
.hero-badge { padding: 10rpx 18rpx; border-radius: 999rpx; background: #FFF0D0; color: #B86B00; font-size: 24rpx; font-weight: 900; }
/* 朗诵秀：人气朗诵 + 本周排行 双Tab */
.recitation-show {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 34rpx;
  background: linear-gradient(160deg, #FFF8F0 0%, #FFF0E8 25%, #F0F4FF 55%, #E8F0FF 100%);
  box-shadow: 0 12rpx 32rpx rgba(255,130,70,0.10), 0 4rpx 12rpx rgba(79,123,255,0.08);
  overflow: hidden;
}
.show-tabs {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}
.show-tab {
  position: relative;
  font-size: 28rpx;
  font-weight: 800;
  color: #9CA3AF;
  padding-bottom: 10rpx;
  transition: color 0.25s;
}
.show-tab.active {
  color: #1F2937;
}
.tab-underline {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(90deg, #FF8A50, #818CF8);
}
.carousel-subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 700;
}
.carousel-swiper {
  height: 220rpx;
}
.carousel-page {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 0 4rpx;
  height: 100%;
}
.carousel-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}
.item-coral {
  background: linear-gradient(135deg, #FFF0E8 0%, #FFE0D0 100%);
  box-shadow: 0 4rpx 14rpx rgba(255,130,70,0.16);
}
.item-sky {
  background: linear-gradient(135deg, #E8F0FF 0%, #D8E4FF 100%);
  box-shadow: 0 4rpx 14rpx rgba(79,123,255,0.14);
}
.carousel-rank {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.carousel-rank-num {
  font-size: 30rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}
.item-coral .carousel-rank {
  background: linear-gradient(135deg, #FF8A50, #FF6030);
}
.item-sky .carousel-rank {
  background: linear-gradient(135deg, #818CF8, #6366F1);
}
/* 第一列：诗 */
.carousel-poem-col {
  flex: 1;
  min-width: 0;
}
.carousel-poem-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1F2937;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.carousel-poem-sub {
  font-size: 20rpx;
  color: #8A8F98;
  font-weight: 700;
  padding-left: 10rpx; /* 对齐「《」括号后的诗名首字 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
/* 第二列：用户名（居中、与播放键拉开间距，往中间靠） */
.carousel-user-col {
  flex-shrink: 0;
  max-width: 150rpx;
  text-align: center;
  margin-left: 24rpx;
  margin-right: 72rpx;
}
.carousel-user-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #5A6478;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.carousel-user-likes {
  font-size: 20rpx;
  font-weight: 700;
  color: #FF6B6B;
  margin-top: 4rpx;
}
.carousel-play-wrap {
  margin-left: 12rpx;
  flex-shrink: 0;
}
.carousel-play-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF8A50 0%, #FF6030 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(255,96,48,0.38);
  position: relative;
}
.carousel-play-btn text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 900;
  line-height: 1;
}
.carousel-play-btn.playing {
  background: linear-gradient(135deg, #818CF8 0%, #6366F1 100%);
  box-shadow: 0 6rpx 18rpx rgba(99,102,241,0.45);
}
.carousel-dots {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin-top: 14rpx;
}
.carousel-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D1D5DB;
  transition: all 0.3s;
}
.carousel-dot.active {
  width: 28rpx;
  border-radius: 6rpx;
  background: #FF7030;
}

.carousel-subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 700;
  margin-bottom: 14rpx;
  text-align: center;
}
.show-empty {
  text-align: center;
  color: #9CA3AF;
  font-size: 24rpx;
  font-weight: 700;
  padding: 40rpx 0;
}

/* 今日学习计划卡 */
.plan-card { padding: 28rpx 26rpx; border-radius: 32rpx; background: linear-gradient(135deg, #EAF2FF 0%, #F3ECFF 100%); box-shadow: 0 16rpx 34rpx rgba(108,140,255,0.16); margin-bottom: 22rpx; }
.plan-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.plan-title { font-size: 32rpx; font-weight: 900; color: #2A3550; }
.plan-progress { font-size: 26rpx; font-weight: 800; color: #6C6FE0; background: rgba(108,111,224,0.12); border-radius: 999rpx; padding: 6rpx 18rpx; }
.plan-bar { height: 14rpx; background: rgba(108,111,224,0.14); border-radius: 999rpx; overflow: hidden; margin-bottom: 18rpx; }
.plan-bar-fill { height: 100%; background: linear-gradient(90deg, #8AB4FF, #6C6FE0); border-radius: 999rpx; transition: width 0.4s ease; min-width: 2rpx; }
.plan-item { display: flex; align-items: center; gap: 16rpx; padding: 18rpx 18rpx; background: rgba(255,255,255,0.86); border-radius: 22rpx; margin-bottom: 12rpx; }
.plan-item.done { opacity: 0.72; }
.plan-check { font-size: 40rpx; width: 48rpx; text-align: center; }
.plan-item-main { flex: 1; min-width: 0; }
.plan-item-title { font-size: 28rpx; font-weight: 800; color: #2A3550; }
.plan-item.done .plan-item-title { text-decoration: line-through; color: #8A93A8; }
.plan-item-sub { font-size: 22rpx; color: #97A0B5; margin-top: 4rpx; }
.plan-item-cta { font-size: 24rpx; font-weight: 800; color: #fff; background: linear-gradient(135deg, #8AB4FF, #6C6FE0); border-radius: 999rpx; padding: 10rpx 20rpx; white-space: nowrap; }
.plan-item-cta.done-tag { color: #6C6FE0; background: rgba(108,111,224,0.12); }
.plan-alldone { text-align: center; font-size: 26rpx; font-weight: 800; color: #6C6FE0; padding: 12rpx 0 4rpx; }
.plan-empty { display: flex; align-items: center; gap: 16rpx; }
.plan-empty-emoji { font-size: 48rpx; }
.plan-empty-text { flex: 1; font-size: 26rpx; color: #5A6478; font-weight: 700; line-height: 1.5; }

.today-card { position: relative; overflow: hidden; padding: 34rpx; border-radius: 36rpx; background: linear-gradient(135deg, #FFF4D8 0%, #FFD9A6 100%); box-shadow: 0 18rpx 38rpx rgba(255,159,69,0.18); }
.today-image { width: 100%; height: 320rpx; display: block; margin-bottom: 24rpx; border-radius: 28rpx; box-shadow: 0 12rpx 26rpx rgba(120, 72, 22, 0.16); background: rgba(255,255,255,0.42); }
.today-label { font-size: 25rpx; color: #A66A23; font-weight: 900; }
.today-title { margin-top: 10rpx; font-size: 52rpx; color: #1F2937; font-weight: 900; }
.today-author { margin-top: 6rpx; font-size: 26rpx; color: #8A5B22; font-weight: 700; }
.today-lines { margin-top: 18rpx; font-size: 32rpx; color: #3B342A; line-height: 1.65; font-weight: 800; }
.today-bottom { display: flex; align-items: flex-end; justify-content: space-between; gap: 16rpx; margin-top: 24rpx; }
.today-tags { flex: 1; display: flex; flex-wrap: wrap; gap: 8rpx; }
.today-tags text { padding: 6rpx 12rpx; border-radius: 999rpx; background: rgba(255,255,255,0.58); color: #9A5B00; font-size: 21rpx; font-weight: 900; }
.today-btn { flex-shrink: 0; padding: 14rpx 22rpx; border-radius: 999rpx; background: #fff; color: #FF7A45; font-size: 25rpx; font-weight: 900; }
.recommend-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.recommend-card { overflow: hidden; padding: 0 0 22rpx; border-radius: 28rpx; background: rgba(255,255,255,0.94); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.065); }
.recommend-image { width: 100%; height: 170rpx; display: block; margin-bottom: 18rpx; background: #FFF4D8; }
.recommend-card .poem-primary-theme, .recommend-card .recommend-title, .recommend-card .recommend-author { margin-left: 22rpx; margin-right: 22rpx; }
.recommend-title { margin-top: 8rpx; font-size: 32rpx; color: #1F2937; font-weight: 900; }
.recommend-author { margin-top: 6rpx; font-size: 24rpx; color: #8A8F98; font-weight: 700; }
.popular-list { display: flex; flex-direction: column; gap: 14rpx; }
.popular-item { display: flex; align-items: center; gap: 14rpx; padding: 18rpx; border-radius: 28rpx; background: rgba(255,255,255,0.94); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.065); }
.popular-rank { width: 50rpx; height: 50rpx; line-height: 50rpx; text-align: center; border-radius: 50%; color: #fff; font-size: 24rpx; font-weight: 900; background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%); }
.popular-info { flex: 1; min-width: 0; }
.popular-title { font-size: 29rpx; color: #1F2937; font-weight: 900; }
.popular-meta { margin-top: 5rpx; font-size: 23rpx; color: #8A8F98; font-weight: 700; }
.popular-play { width: 58rpx; height: 58rpx; line-height: 58rpx; border-radius: 50%; text-align: center; color: #1E88FF; background: #EAF4FF; font-size: 26rpx; font-weight: 900; }
.empty-popular { padding: 26rpx; border-radius: 28rpx; background: rgba(255,255,255,0.88); color: #8A8F98; text-align: center; font-size: 26rpx; font-weight: 700; }
.task-mini-card { padding: 24rpx; border-radius: 30rpx; background: rgba(255,255,255,0.94); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.065); }
.task-mini-item { padding: 12rpx 0; font-size: 28rpx; color: #1F2937; font-weight: 850; }
.task-mini-item.done { color: #45B96C; }

/* 个性化模块标题：更像儿童诗词 App 的小招牌 */
.section-title {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  width: auto;
  margin: 42rpx 0 22rpx;
  padding: 8rpx 18rpx 10rpx;
  border-radius: 999rpx;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
  letter-spacing: 1rpx;
  color: #172033;
  background: rgba(255, 255, 255, 0.56);
  box-shadow: 0 10rpx 24rpx rgba(31, 35, 46, 0.05), inset 0 1rpx 0 rgba(255,255,255,0.75);
}

.section-title::after {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 6rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 205, 86, 0.42), rgba(255, 255, 255, 0));
  z-index: -1;
}

.section-title text:first-child {
  display: inline-block;
  color: #172033;
  text-shadow: 0 3rpx 0 rgba(255,255,255,0.75), 0 8rpx 16rpx rgba(31,35,46,0.08);
}

/* 第一个模块：为你推荐，暖黄色月光感 */
.container > .section-title:nth-of-type(1) text:first-child {
  color: #9A4D00;
}
.container > .section-title:nth-of-type(1)::after {
  background: linear-gradient(90deg, rgba(255, 202, 70, 0.58), rgba(255, 236, 179, 0));
}

/* 第二个模块：人气朗诵，舞台紫蓝感 */
.container > .section-title:nth-of-type(2) text:first-child {
  color: #4338CA;
}
.container > .section-title:nth-of-type(2)::after {
  background: linear-gradient(90deg, rgba(129, 140, 248, 0.45), rgba(191, 219, 254, 0));
}

/* 第三个模块：主题探索，青绿色探索感 */
.container > .section-title:nth-of-type(3) text:first-child {
  color: #047857;
}
.container > .section-title:nth-of-type(3)::after {
  background: linear-gradient(90deg, rgba(52, 211, 153, 0.44), rgba(204, 251, 241, 0));
}

.row-title {
  display: flex;
  width: 100%;
  box-sizing: border-box;
  justify-content: space-between;
  border-radius: 28rpx;
  padding: 10rpx 18rpx 12rpx;
}

.row-title .more {
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  color: #A16207;
  background: rgba(255, 243, 197, 0.92);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.8);
}

/* 首页卡片字体统一：标题更有诗词味 */
.poem-title,
.recommend-title {
  color: #172033;
  font-weight: 950;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 0 rgba(255,255,255,0.75);
}

.recommend-card:nth-child(3n + 1) .recommend-title { color: #B45309; }
.recommend-card:nth-child(3n + 2) .recommend-title { color: #2563EB; }
.recommend-card:nth-child(3n + 3) .recommend-title { color: #047857; }

.recommend-card {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,250,240,0.96) 100%);
  border: 1rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 16rpx 34rpx rgba(31,35,46,0.08), inset 0 1rpx 0 rgba(255,255,255,0.9);
}

.poem-primary-theme {
  display: inline-flex;
  width: fit-content;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
