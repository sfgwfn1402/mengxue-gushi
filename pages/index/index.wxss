/* 学习状态悬浮球 + 弹出面板 */
/* 苹果质感立体球：径向高光 + 内高光/内阴影 + 外投影 */
.study-ball { position: fixed; width: 112rpx; height: 112rpx; border-radius: 50%; overflow: hidden;
  background: radial-gradient(circle at 34% 28%, #FFE6B0 0%, #FFB15D 42%, #FF7A2E 78%, #EC6716 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  box-shadow: 0 14rpx 28rpx rgba(236,103,22,0.45),
              inset 0 6rpx 12rpx rgba(255,255,255,0.55),
              inset 0 -12rpx 20rpx rgba(180,70,0,0.4);
  z-index: 90; transition: transform 0.2s ease, box-shadow 0.2s ease; }
.study-ball.hover { transform: scale(1.22); box-shadow: 0 20rpx 38rpx rgba(236,103,22,0.5), inset 0 6rpx 12rpx rgba(255,255,255,0.6), inset 0 -12rpx 20rpx rgba(180,70,0,0.4); }
.study-ball-gloss { position: absolute; top: 10rpx; left: 18rpx; width: 56rpx; height: 38rpx; border-radius: 50%;
