/* 朗诵卡：诗画配图当封面 + 中央播放键 + 底部渐变诗名 */
.recitation-cover { position: relative; width: 100%; height: 300rpx; overflow: hidden; }
.recitation-cover-bg { position: absolute; left: 0; top: 0; width: 100%; height: 100%; display: block; }
/* 配图缺失时的渐变兜底（按 poem_id 分 6 档色，避免整墙同色） */
.recitation-cover.tone-0 { background: linear-gradient(135deg, #FFE0E0, #FFEFD2); }
.recitation-cover.tone-1 { background: linear-gradient(135deg, #DCEBFF, #E7F4FF); }
.recitation-cover.tone-2 { background: linear-gradient(135deg, #E2F7E2, #EEFBE5); }
.recitation-cover.tone-3 { background: linear-gradient(135deg, #F0E6FF, #F7EEFF); }
.recitation-cover.tone-4 { background: linear-gradient(135deg, #FFE8D2, #FFF2DE); }
.recitation-cover.tone-5 { background: linear-gradient(135deg, #D6F2F0, #E6FAF6); }
.recitation-cover-mic { position: absolute; left: 0; top: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 88rpx; opacity: 0.55; }
