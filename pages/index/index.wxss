.eq-bar:nth-child(1) { height: 16rpx; animation-delay: 0s; }
.eq-bar:nth-child(2) { height: 34rpx; animation-delay: 0.25s; }
.eq-bar:nth-child(3) { height: 22rpx; animation-delay: 0.5s; }
@keyframes eqjump { 0%, 100% { transform: scaleY(0.4); } 50% { transform: scaleY(1); } }
