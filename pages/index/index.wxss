.home-tabs { position: sticky; top: 0; z-index: 20; display: flex; justify-content: center; gap: 18rpx; margin: -28rpx -24rpx 24rpx; padding: 22rpx 24rpx 18rpx; background: rgba(246,248,252,0.96); backdrop-filter: blur(18rpx); }
