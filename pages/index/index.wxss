/* pages/index/index.wxss - iOS 儿童学习 App 风格 */
page {
  min-height: 100vh;
  background: #FFF2DE;
  color: #1D1D1F;
}

.container {
  padding: 28rpx 24rpx 44rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F6F8FC 0%, #FFF7EA 62%, #FFF2DE 100%);
}

.header {
  text-align: center;
  padding: 28rpx 0 20rpx;
}

.logo {
  width: 132rpx;
  height: 132rpx;
  line-height: 132rpx;
  margin: 0 auto 18rpx;
  border-radius: 34rpx;
  font-size: 82rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 18rpx 38rpx rgba(31,35,46,0.09), inset 0 1rpx 0 rgba(255,255,255,0.9);
}

.title {
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #1F2937;
  letter-spacing: 2rpx;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #8A8F98;
}

.source-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(31,35,46,0.08);
}

.source-badge.online { background: linear-gradient(180deg, #6DD98A 0%, #45B96C 100%); }
.source-badge.offline { background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); }

.source-error {
  margin: 14rpx auto 0;
  max-width: 640rpx;
  color: #C2410C;
  background: rgba(255, 237, 213, 0.92);
  border-radius: 18rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  word-break: break-all;
}

.maintenance,
.banner,
.poem-card,
.idiom-card,
.stats-card,
.level-card {
  background: rgba(255,255,255,0.94);
  border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.075), 0 2rpx 8rpx rgba(31,35,46,0.04);
}

.maintenance {
  padding: 60rpx 30rpx;
  margin: 28rpx 0;
  text-align: center;
}

.maintenance-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #FF7A45;
}

.maintenance-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #8A8F98;
}

.banner {
  position: relative;
  overflow: hidden;
  padding: 38rpx;
  margin: 28rpx 0;
  text-align: center;
  background: linear-gradient(135deg, #FFD66B 0%, #FF9F45 100%);
  box-shadow: 0 18rpx 38rpx rgba(255, 159, 69, 0.22), inset 0 1rpx 0 rgba(255,255,255,0.35);
}

.banner::after {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -80rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.22);
}

.banner-text {
  position: relative;
  font-size: 36rpx;
  color: #fff;
  font-weight: 900;
}

.banner-desc {
  position: relative;
  font-size: 26rpx;
  color: rgba(255,255,255,0.92);
  margin-top: 10rpx;
  font-weight: 700;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1F2937;
  margin: 34rpx 0 18rpx;
  padding-left: 0;
  border-left: none;
}

.poem-card,
.idiom-card {
  padding: 28rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
}

.poem-card:active,
.idiom-card:active,
.level-card:active {
  transform: scale(0.985);
  opacity: 0.92;
}

.poem-icon {
  width: 94rpx;
  height: 94rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.40), 0 10rpx 18rpx rgba(255,173,50,0.20);
}

.poem-icon.blue {
  background: linear-gradient(180deg, #71B8FF 0%, #3D8CFF 100%);
}

.poem-info { flex: 1; min-width: 0; }

.poem-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1F2937;
}

.poem-author {
  font-size: 25rpx;
  color: #8A8F98;
  margin-top: 8rpx;
}

.difficulty { display: flex; gap: 6rpx; }
.star { font-size: 24rpx; color: #D9DDE5; }
.star.active { color: #FFBE32; }
.poem-arrow { font-size: 34rpx; color: #C8CDD6; }

.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #8A8F98;
  font-size: 24rpx;
  font-weight: 700;
}

.stat-num {
  font-size: 42rpx;
  font-weight: 900;
  color: #FF6B6B;
}

.level-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.level-card {
  padding: 26rpx 10rpx;
  text-align: center;
}

.level-emoji { font-size: 44rpx; }
.level-name { font-size: 29rpx; font-weight: 900; color: #1F2937; margin-top: 8rpx; }
.level-count { font-size: 23rpx; color: #8A8F98; margin-top: 6rpx; }

.poem-theme-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 10rpx 0 2rpx;
}

.poem-theme-tag {
  max-width: 176rpx;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #FFF4D8;
  color: #9A6A2E;
  font-size: 21rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poem-primary-theme {
  display: inline-flex;
  align-items: center;
  max-width: 220rpx;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 14rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #FFF4D8 0%, #FFE4A8 100%);
  color: #9A5B00;
  font-size: 21rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 34rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 16rpx 36rpx rgba(31,35,46,0.07);
}
.hello-title { font-size: 38rpx; font-weight: 900; color: #1F2937; }
.hello-subtitle { margin-top: 8rpx; font-size: 25rpx; color: #8A8F98; font-weight: 700; }
.hero-badge { padding: 10rpx 18rpx; border-radius: 999rpx; background: #FFF0D0; color: #B86B00; font-size: 24rpx; font-weight: 900; }
.today-card { position: relative; overflow: hidden; padding: 34rpx; border-radius: 36rpx; background: linear-gradient(135deg, #FFF4D8 0%, #FFD9A6 100%); box-shadow: 0 18rpx 38rpx rgba(255,159,69,0.18); }
.today-image { width: 100%; height: 320rpx; display: block; margin-bottom: 24rpx; border-radius: 28rpx; box-shadow: 0 12rpx 26rpx rgba(120, 72, 22, 0.16); background: rgba(255,255,255,0.42); }
.today-label { font-size: 25rpx; color: #A66A23; font-weight: 900; }
.today-title { margin-top: 10rpx; font-size: 52rpx; color: #1F2937; font-weight: 900; }
.today-author { margin-top: 6rpx; font-size: 26rpx; color: #8A5B22; font-weight: 700; }
.today-lines { margin-top: 18rpx; font-size: 32rpx; color: #3B342A; line-height: 1.65; font-weight: 800; }
.today-bottom { display: flex; align-items: flex-end; justify-content: space-between; gap: 16rpx; margin-top: 24rpx; }
.today-tags { flex: 1; display: flex; flex-wrap: wrap; gap: 8rpx; }
.today-tags text { padding: 6rpx 12rpx; border-radius: 999rpx; background: rgba(255,255,255,0.58); color: #9A5B00; font-size: 21rpx; font-weight: 900; }
.today-btn { flex-shrink: 0; padding: 14rpx 22rpx; border-radius: 999rpx; background: #fff; color: #FF7A45; font-size: 25rpx; font-weight: 900; }
.recommend-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.recommend-card { overflow: hidden; padding: 0 0 22rpx; border-radius: 28rpx; background: rgba(255,255,255,0.94); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.065); }
.recommend-image { width: 100%; height: 170rpx; display: block; margin-bottom: 18rpx; background: #FFF4D8; }
.recommend-card .poem-primary-theme, .recommend-card .recommend-title, .recommend-card .recommend-author { margin-left: 22rpx; margin-right: 22rpx; }
.recommend-title { margin-top: 8rpx; font-size: 32rpx; color: #1F2937; font-weight: 900; }
.recommend-author { margin-top: 6rpx; font-size: 24rpx; color: #8A8F98; font-weight: 700; }
.popular-list { display: flex; flex-direction: column; gap: 14rpx; }
.popular-item { display: flex; align-items: center; gap: 14rpx; padding: 18rpx; border-radius: 28rpx; background: rgba(255,255,255,0.94); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.065); }
.popular-rank { width: 50rpx; height: 50rpx; line-height: 50rpx; text-align: center; border-radius: 50%; color: #fff; font-size: 24rpx; font-weight: 900; background: linear-gradient(180deg, #FFD66B 0%, #FFAD32 100%); }
.popular-info { flex: 1; min-width: 0; }
.popular-title { font-size: 29rpx; color: #1F2937; font-weight: 900; }
.popular-meta { margin-top: 5rpx; font-size: 23rpx; color: #8A8F98; font-weight: 700; }
.popular-play { width: 58rpx; height: 58rpx; line-height: 58rpx; border-radius: 50%; text-align: center; color: #1E88FF; background: #EAF4FF; font-size: 26rpx; font-weight: 900; }
.empty-popular { padding: 26rpx; border-radius: 28rpx; background: rgba(255,255,255,0.88); color: #8A8F98; text-align: center; font-size: 26rpx; font-weight: 700; }
.task-mini-card { padding: 24rpx; border-radius: 30rpx; background: rgba(255,255,255,0.94); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.065); }
.task-mini-item { padding: 12rpx 0; font-size: 28rpx; color: #1F2937; font-weight: 850; }
.task-mini-item.done { color: #45B96C; }

/* 个性化模块标题：更像儿童诗词 App 的小招牌 */
.section-title {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  width: auto;
  margin: 42rpx 0 22rpx;
  padding: 8rpx 18rpx 10rpx;
  border-radius: 999rpx;
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 950;
  letter-spacing: 1rpx;
  color: #172033;
  background: rgba(255, 255, 255, 0.56);
  box-shadow: 0 10rpx 24rpx rgba(31, 35, 46, 0.05), inset 0 1rpx 0 rgba(255,255,255,0.75);
}

.section-title::after {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 6rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 205, 86, 0.42), rgba(255, 255, 255, 0));
  z-index: -1;
}

.section-title text:first-child {
  display: inline-block;
  color: #172033;
  text-shadow: 0 3rpx 0 rgba(255,255,255,0.75), 0 8rpx 16rpx rgba(31,35,46,0.08);
}

/* 第一个模块：为你推荐，暖黄色月光感 */
.container > .section-title:nth-of-type(1) text:first-child {
  color: #9A4D00;
}
.container > .section-title:nth-of-type(1)::after {
  background: linear-gradient(90deg, rgba(255, 202, 70, 0.58), rgba(255, 236, 179, 0));
}

/* 第二个模块：人气朗诵，舞台紫蓝感 */
.container > .section-title:nth-of-type(2) text:first-child {
  color: #4338CA;
}
.container > .section-title:nth-of-type(2)::after {
  background: linear-gradient(90deg, rgba(129, 140, 248, 0.45), rgba(191, 219, 254, 0));
}

/* 第三个模块：主题探索，青绿色探索感 */
.container > .section-title:nth-of-type(3) text:first-child {
  color: #047857;
}
.container > .section-title:nth-of-type(3)::after {
  background: linear-gradient(90deg, rgba(52, 211, 153, 0.44), rgba(204, 251, 241, 0));
}

.row-title {
  display: flex;
  width: 100%;
  box-sizing: border-box;
  justify-content: space-between;
  border-radius: 28rpx;
  padding: 10rpx 18rpx 12rpx;
}

.row-title .more {
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  color: #A16207;
  background: rgba(255, 243, 197, 0.92);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.8);
}

/* 首页卡片字体统一：标题更有诗词味 */
.poem-title,
.recommend-title {
  color: #172033;
  font-weight: 950;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 0 rgba(255,255,255,0.75);
}

.recommend-card:nth-child(3n + 1) .recommend-title { color: #B45309; }
.recommend-card:nth-child(3n + 2) .recommend-title { color: #2563EB; }
.recommend-card:nth-child(3n + 3) .recommend-title { color: #047857; }

.recommend-card {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,250,240,0.96) 100%);
  border: 1rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 16rpx 34rpx rgba(31,35,46,0.08), inset 0 1rpx 0 rgba(255,255,255,0.9);
}

.poem-primary-theme {
  display: inline-flex;
  width: fit-content;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: #8A4B00;
  font-size: 21rpx;
  font-weight: 900;
  background: linear-gradient(180deg, #FFF7D6 0%, #FFE7A3 100%);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.82);
}

.popular-name {
  font-weight: 950;
  color: #4338CA;
  letter-spacing: 1rpx;
}

.theme-card-name,
.theme-name {
  font-weight: 950;
  letter-spacing: 1rpx;
  color: #075985;
}

/* 参考儿童内容 App：糖果描边大标题 */
.section-title text:first-child {
  font-size: 42rpx;
  font-weight: 950;
  letter-spacing: 2rpx;
  -webkit-text-stroke: 1rpx rgba(255,255,255,0.92);
  text-shadow:
    0 2rpx 0 #FFFFFF,
    2rpx 0 0 #FFFFFF,
    -2rpx 0 0 #FFFFFF,
    0 -2rpx 0 #FFFFFF,
    0 7rpx 0 rgba(255, 199, 64, 0.26),
    0 12rpx 18rpx rgba(31,35,46,0.12);
}

.container > .section-title:nth-of-type(1) text:first-child {
  color: #FF9F1C;
  text-shadow:
    0 2rpx 0 #FFFFFF,
    2rpx 0 0 #FFFFFF,
    -2rpx 0 0 #FFFFFF,
    0 -2rpx 0 #FFFFFF,
    0 7rpx 0 rgba(255, 210, 77, 0.34),
    0 12rpx 18rpx rgba(255, 159, 28, 0.18);
}

.container > .section-title:nth-of-type(2) text:first-child {
  color: #3B82F6;
  text-shadow:
    0 2rpx 0 #FFFFFF,
    2rpx 0 0 #FFFFFF,
    -2rpx 0 0 #FFFFFF,
    0 -2rpx 0 #FFFFFF,
    0 7rpx 0 rgba(147, 197, 253, 0.45),
    0 12rpx 18rpx rgba(59, 130, 246, 0.18);
}

.container > .section-title:nth-of-type(3) text:first-child {
  color: #10B981;
  text-shadow:
    0 2rpx 0 #FFFFFF,
    2rpx 0 0 #FFFFFF,
    -2rpx 0 0 #FFFFFF,
    0 -2rpx 0 #FFFFFF,
    0 7rpx 0 rgba(110, 231, 183, 0.45),
    0 12rpx 18rpx rgba(16, 185, 129, 0.18);
}

.row-title .more {
  color: #D79A00;
  font-size: 25rpx;
  -webkit-text-stroke: 0;
  text-shadow: 0 2rpx 0 #FFFFFF, 0 6rpx 12rpx rgba(215,154,0,0.14);
}

.recommend-title,
.poem-title,
.popular-name,
.theme-card-name,
.theme-name {
  -webkit-text-stroke: 0.5rpx rgba(255,255,255,0.82);
  text-shadow:
    0 2rpx 0 rgba(255,255,255,0.9),
    0 7rpx 14rpx rgba(31,35,46,0.08);
}

/* 回退：去掉重描边糖果字，恢复干净轻盈标题 */
.section-title text:first-child,
.recommend-title,
.poem-title,
.popular-name,
.theme-card-name,
.theme-name,
.row-title .more {
  -webkit-text-stroke: 0 !important;
  text-shadow: none !important;
}

.section-title text:first-child {
  font-size: 38rpx !important;
  font-weight: 950 !important;
  letter-spacing: 1rpx !important;
}

.container > .section-title:nth-of-type(1) text:first-child { color: #9A4D00 !important; }
.container > .section-title:nth-of-type(2) text:first-child { color: #4338CA !important; }
.container > .section-title:nth-of-type(3) text:first-child { color: #047857 !important; }

.row-title .more {
  color: #A16207 !important;
  font-size: 22rpx !important;
}

/* 最终回退到初版：取消标题个性化 */
.section-title {
  display: block !important;
  width: auto !important;
  margin: 34rpx 0 18rpx !important;
  padding: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  border: none !important;
  font-size: 34rpx !important;
  line-height: normal !important;
  font-weight: 900 !important;
  letter-spacing: 0 !important;
  color: #1F2937 !important;
}

.section-title::after,
.section-title::before {
  display: none !important;
  content: none !important;
}

.section-title text:first-child,
.container > .section-title:nth-of-type(1) text:first-child,
.container > .section-title:nth-of-type(2) text:first-child,
.container > .section-title:nth-of-type(3) text:first-child {
  display: inline !important;
  font-size: inherit !important;
  font-weight: inherit !important;
  letter-spacing: 0 !important;
  color: #1F2937 !important;
  -webkit-text-stroke: 0 !important;
  text-shadow: none !important;
}

.row-title {
  display: flex !important;
  width: auto !important;
  box-sizing: border-box !important;
  justify-content: space-between !important;
  border-radius: 0 !important;
  padding: 0 !important;
}

.row-title .more {
  padding: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  color: #8A8F98 !important;
  font-size: 24rpx !important;
  font-weight: 700 !important;
  -webkit-text-stroke: 0 !important;
  text-shadow: none !important;
}

.recommend-title,
.poem-title,
.popular-name,
.theme-card-name,
.theme-name {
  -webkit-text-stroke: 0 !important;
  text-shadow: none !important;
}

.recommend-title { color: #1F2937 !important; font-weight: 900 !important; letter-spacing: 0 !important; }
.poem-title { color: #1F2937 !important; font-weight: 900 !important; letter-spacing: 0 !important; }
.popular-name { color: inherit !important; font-weight: inherit !important; letter-spacing: 0 !important; }
.theme-card-name, .theme-name { color: inherit !important; font-weight: inherit !important; letter-spacing: 0 !important; }
.poem-primary-theme { box-shadow: none !important; }

/* 分类学习版：首页学习路径 */
.learning-path-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.learning-path-card {
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  box-sizing: border-box;
  color: #1F2937;
  box-shadow: 0 16rpx 34rpx rgba(31,35,46,0.075), inset 0 1rpx 0 rgba(255,255,255,0.58);
  border: 1rpx solid rgba(255,255,255,0.78);
}

.learning-path-card:active,
.child-theme:active,
.task-card:active { transform: scale(0.985); opacity: 0.92; }

.path-0 { background: linear-gradient(135deg, #FFF4C2 0%, #FFD66B 100%); }
.path-1 { background: linear-gradient(135deg, #FFE0E9 0%, #FF9FBE 100%); }
.path-2 { background: linear-gradient(135deg, #DFFFE9 0%, #79D99A 100%); }
.path-3 { background: linear-gradient(135deg, #DDEBFF 0%, #8DBBFF 100%); }

.path-emoji { font-size: 44rpx; }
.path-title { margin-top: 10rpx; font-size: 30rpx; font-weight: 900; }
.path-desc { margin-top: 6rpx; font-size: 23rpx; font-weight: 700; color: rgba(31,41,55,0.68); }

.child-theme-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.child-theme {
  min-height: 126rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.94);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 26rpx rgba(31,35,46,0.065);
  border: 1rpx solid rgba(255,255,255,0.82);
}

.child-theme-emoji { font-size: 42rpx; }
.child-theme-name { margin-top: 8rpx; font-size: 24rpx; font-weight: 900; color: #374151; }

.task-list { display: flex; flex-direction: column; gap: 14rpx; }
.task-card {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.95);
  box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.07);
}
.task-emoji {
  width: 74rpx;
  height: 74rpx;
  border-radius: 24rpx;
  background: #FFF3D1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 18rpx;
}
.task-main { flex: 1; min-width: 0; }
.task-title { font-size: 29rpx; font-weight: 900; color: #1F2937; }
.task-sub { margin-top: 5rpx; font-size: 23rpx; color: #8A8F98; font-weight: 700; }
.task-go { font-size: 38rpx; color: #C8CDD6; }

.continue-card {
  display: flex;
  align-items: center;
  margin: 22rpx 0 8rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #EAF3FF 0%, #FFFFFF 100%);
  box-shadow: 0 16rpx 34rpx rgba(31,35,46,0.075), inset 0 1rpx 0 rgba(255,255,255,0.75);
}
.continue-card:active { transform: scale(0.985); opacity: 0.92; }
.continue-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 24rpx;
  background: #DDEBFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  margin-right: 18rpx;
}
.continue-main { flex: 1; min-width: 0; }
.continue-label { font-size: 22rpx; font-weight: 900; color: #3D8CFF; }
.continue-title { margin-top: 4rpx; font-size: 32rpx; font-weight: 900; color: #1F2937; }
.continue-sub { margin-top: 6rpx; font-size: 23rpx; font-weight: 700; color: #8A8F98; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.continue-go { font-size: 42rpx; color: #9CA3AF; }
.home-tabs { position: sticky; top: 0; z-index: 20; display: flex; justify-content: center; gap: 18rpx; margin: -28rpx -24rpx 24rpx; padding: 22rpx 24rpx 18rpx; background: rgba(246,248,252,0.96); backdrop-filter: blur(18rpx); }
.home-tab { padding: 14rpx 34rpx; border-radius: 999rpx; color: #8A8F98; font-size: 30rpx; font-weight: 900; background: rgba(255,255,255,0.86); }
.home-tab.active { color: #fff; background: linear-gradient(180deg, #FFB15D 0%, #FF7A45 100%); box-shadow: 0 12rpx 24rpx rgba(255,122,69,0.20); }
.discover-header { padding: 30rpx; border-radius: 32rpx; background: linear-gradient(135deg, #FFF0D0, #FFD9A6); margin-bottom: 20rpx; box-shadow: 0 16rpx 36rpx rgba(255,159,69,0.14); }
.discover-title { font-size: 38rpx; color: #1F2937; font-weight: 900; }
.discover-sub { margin-top: 8rpx; font-size: 25rpx; color: #8A5B22; font-weight: 700; }
.discover-filters { display: flex; gap: 14rpx; margin-bottom: 22rpx; }
.discover-filter { padding: 12rpx 24rpx; border-radius: 999rpx; background: rgba(255,255,255,0.9); color: #8A8F98; font-size: 25rpx; font-weight: 900; }
.discover-filter.active { background: #1F2937; color: #fff; }
.discover-waterfall { column-count: 2; column-gap: 16rpx; }
.discover-card { break-inside: avoid; margin-bottom: 16rpx; border-radius: 26rpx; overflow: hidden; background: rgba(255,255,255,0.96); box-shadow: 0 14rpx 30rpx rgba(31,35,46,0.07); }
.discover-image { width: 100%; height: 300rpx; display: block; background: #FFF4D8; }
.recitation-cover { padding: 28rpx 18rpx; text-align: center; background: linear-gradient(135deg, #FFE6E6, #FFF2D2); }
.recitation-icon { font-size: 64rpx; }
.recitation-poem { margin-top: 8rpx; font-size: 28rpx; color: #1F2937; font-weight: 900; }
.recitation-play { display: inline-flex; margin-top: 16rpx; padding: 10rpx 18rpx; border-radius: 999rpx; background: #fff; color: #FF6B6B; font-size: 23rpx; font-weight: 900; }
.discover-card-body { padding: 18rpx; }
.discover-card-title { font-size: 28rpx; color: #1F2937; font-weight: 900; line-height: 1.35; }
.discover-card-poem { margin-top: 8rpx; font-size: 23rpx; color: #8A8F98; font-weight: 700; }
.discover-user-row { display: flex; align-items: center; gap: 8rpx; margin-top: 16rpx; }
.discover-avatar { width: 34rpx; height: 34rpx; border-radius: 50%; background: #FFF0D0; font-size: 20rpx; text-align: center; line-height: 34rpx; }
.discover-nickname { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #6B7280; font-size: 22rpx; font-weight: 700; }
.discover-like { color: #8A8F98; font-size: 22rpx; font-weight: 800; padding: 6rpx 0 6rpx 12rpx; }
.discover-like.liked { color: #FF4D6D; }
.discover-empty { margin-top: 80rpx; text-align: center; color: #8A8F98; font-size: 28rpx; font-weight: 800; }
