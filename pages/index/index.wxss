.review-banner { display: flex; align-items: center; gap: 18rpx; margin: 0 0 22rpx; padding: 22rpx 24rpx; border-radius: 30rpx; background: linear-gradient(135deg, #E3F0FF 0%, #D6E8FF 100%); box-shadow: 0 12rpx 28rpx rgba(80,130,220,0.14); }
