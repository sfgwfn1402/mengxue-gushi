.study-panel { width: 90%; max-width: 660rpx; max-height: 72vh; overflow-y: auto; -webkit-overflow-scrolling: touch; background: #FFF8EA; border-radius: 32rpx; padding: 26rpx 24rpx 16rpx; box-shadow: 0 18rpx 50rpx rgba(0,0,0,0.25); animation: study-rise 0.28s ease; }
