page { background: #F5F7FB; }
.container { padding: 24rpx; }

.range-tabs { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.range-tab { flex: 1; text-align: center; padding: 18rpx 0; border-radius: 16rpx; background: #fff; color: #5A6472; font-size: 28rpx; font-weight: 700; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.range-tab.active { background: linear-gradient(135deg, #6C8CFF, #5A7BE0); color: #fff; }

.loading, .empty { text-align: center; color: #9AA3B0; font-size: 26rpx; padding: 40rpx 0; }

.summary { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.summary-card { flex: 1; background: #fff; border-radius: 24rpx; padding: 32rpx 0; text-align: center; box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05); }
.summary-num { font-size: 56rpx; font-weight: 900; color: #2A3550; line-height: 1; }
.summary-label { font-size: 24rpx; color: #8A93A3; margin-top: 12rpx; }

.section { background: #fff; border-radius: 24rpx; padding: 28rpx 24rpx; margin-bottom: 24rpx; box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05); }
.section-title { font-size: 30rpx; font-weight: 800; color: #2A3550; margin-bottom: 20rpx; }

.daily-bar-row { display: flex; align-items: center; gap: 14rpx; margin-bottom: 16rpx; }
.daily-day { width: 80rpx; font-size: 22rpx; color: #8A93A3; }
.daily-bar-track { flex: 1; height: 24rpx; background: #EEF1F7; border-radius: 999rpx; overflow: hidden; }
.daily-bar-fill { height: 100%; background: linear-gradient(90deg, #8AB4FF, #5A7BE0); border-radius: 999rpx; min-width: 4rpx; }
.daily-val { width: 200rpx; text-align: right; font-size: 20rpx; color: #8A93A3; }

.event-row { display: flex; justify-content: space-between; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #F0F2F6; }
.event-row:last-child { border-bottom: none; }
.event-label { font-size: 28rpx; color: #3A4456; font-weight: 600; }
.event-count { font-size: 30rpx; color: #5A7BE0; font-weight: 800; }

.poem-row { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid #F0F2F6; }
.poem-row:last-child { border-bottom: none; }
.poem-rank { width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center; border-radius: 50%; background: #EEF1F7; color: #5A6472; font-size: 24rpx; font-weight: 800; }
.poem-row:nth-child(1) .poem-rank { background: #FFE7B8; color: #B5651D; }
.poem-title { flex: 1; font-size: 28rpx; color: #3A4456; }
.poem-count { font-size: 26rpx; color: #8A93A3; }

.tip { text-align: center; font-size: 22rpx; color: #AEB6C2; padding: 16rpx 0 40rpx; }
