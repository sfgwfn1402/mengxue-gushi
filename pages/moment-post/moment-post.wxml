<view class="post-page">
  <view class="post-card">
    <view class="post-grid">
      <view class="post-thumb" wx:for="{{images}}" wx:key="*this">
        <image class="post-thumb-img" src="{{item}}" mode="aspectFill" data-index="{{index}}" bindtap="previewImage"></image>
        <view class="post-thumb-del" data-index="{{index}}" catchtap="removeImage">×</view>
      </view>
      <view wx:if="{{images.length < max}}" class="post-add" bindtap="chooseImage">
        <view class="post-add-plus">＋</view>
        <view class="post-add-text">{{images.length}}/{{max}}</view>
      </view>
    </view>

    <textarea class="post-textarea" placeholder="说点什么吧～孩子的作品、日常、心情都可以分享"
      value="{{content}}" bindinput="onContentInput" maxlength="300" auto-height></textarea>

    <view class="post-tip">💡 发布后需审核，通过才会公开。请勿上传含他人隐私或不适宜内容。</view>

    <button class="post-btn {{publishing ? 'loading' : ''}}" bindtap="publish" disabled="{{publishing}}">发布到社区</button>
  </view>
</view>
