<view class="post-page">
  <view class="post-card">
    <view class="post-img-wrap" bindtap="chooseImage">
      <image wx:if="{{imagePath}}" class="post-img" src="{{imagePath}}" mode="aspectFill"></image>
      <view wx:else class="post-img-ph">
        <view class="ph-emoji">📷</view>
        <view class="ph-text">选一张孩子的照片</view>
      </view>
    </view>

    <textarea class="post-textarea" placeholder="说点什么吧，比如：今天宝宝读了《静夜思》～"
      value="{{content}}" bindinput="onContentInput" maxlength="300" auto-height></textarea>

    <view class="post-tip">💡 发布后需审核，通过才会公开。请勿上传含他人隐私或不适宜内容。</view>

    <button class="post-btn {{publishing ? 'loading' : ''}}" bindtap="publish" disabled="{{publishing}}">发布到亲子广场</button>
  </view>
</view>
