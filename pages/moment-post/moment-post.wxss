page { background: #FFF2F6; }
.post-page { padding: 24rpx; box-sizing: border-box; }
.post-card { background: #fff; border-radius: 28rpx; padding: 26rpx; box-shadow: 0 12rpx 28rpx rgba(200,100,140,0.08); }

.post-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }
.post-thumb { position: relative; width: calc((100% - 28rpx) / 3); height: 210rpx; border-radius: 16rpx; overflow: hidden; background: #FBEFF3; }
.post-thumb-img { width: 100%; height: 100%; display: block; }
.post-thumb-del { position: absolute; right: 6rpx; top: 6rpx; width: 40rpx; height: 40rpx; line-height: 38rpx; text-align: center; border-radius: 50%; background: rgba(0,0,0,0.5); color: #fff; font-size: 32rpx; }
.post-add { width: calc((100% - 28rpx) / 3); height: 210rpx; border-radius: 16rpx; background: #FBEFF3; border: 2rpx dashed #F0B9CC; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.post-add-plus { font-size: 60rpx; color: #E08CAA; line-height: 1; }
.post-add-text { font-size: 22rpx; color: #C98AA4; margin-top: 8rpx; }

.post-textarea { width: 100%; box-sizing: border-box; min-height: 160rpx; margin-top: 24rpx; padding: 20rpx; background: #FBF6F8; border-radius: 18rpx; font-size: 28rpx; color: #3A2E35; line-height: 1.6; }

.post-tip { font-size: 22rpx; color: #B89AA6; line-height: 1.6; margin: 18rpx 4rpx; }

.post-btn { width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center; line-height: 1; margin-top: 12rpx; padding: 0; background: linear-gradient(135deg, #FF8FB1, #FF6B9D); color: #fff; border-radius: 999rpx; font-size: 30rpx; font-weight: 900; border: none; }
.post-btn.loading { opacity: 0.6; }
.post-btn::after { border: none; }
