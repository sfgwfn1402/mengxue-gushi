page { background: #FFF2F6; }
.post-page { padding: 24rpx; box-sizing: border-box; }
.post-card { background: #fff; border-radius: 28rpx; padding: 26rpx; box-shadow: 0 12rpx 28rpx rgba(200,100,140,0.08); }

.post-img-wrap { width: 100%; height: 520rpx; border-radius: 22rpx; overflow: hidden; background: #FBEFF3; display: flex; align-items: center; justify-content: center; }
.post-img { width: 100%; height: 100%; display: block; }
.post-img-ph { text-align: center; }
.ph-emoji { font-size: 90rpx; }
.ph-text { font-size: 26rpx; color: #C98AA4; margin-top: 16rpx; }

.post-textarea { width: 100%; box-sizing: border-box; min-height: 160rpx; margin-top: 24rpx; padding: 20rpx; background: #FBF6F8; border-radius: 18rpx; font-size: 28rpx; color: #3A2E35; line-height: 1.6; }

.post-tip { font-size: 22rpx; color: #B89AA6; line-height: 1.6; margin: 18rpx 4rpx; }

.post-btn { width: 100%; height: 88rpx; line-height: 88rpx; margin-top: 12rpx; background: linear-gradient(135deg, #FF8FB1, #FF6B9D); color: #fff; border-radius: 999rpx; font-size: 30rpx; font-weight: 900; border: none; }
.post-btn.loading { opacity: 0.6; }
.post-btn::after { border: none; }
