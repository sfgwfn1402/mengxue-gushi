  "10": {
    "poemId": 10,
    "title": "清明",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.246,
    "skipSegments": 3,
    "segmentCount": 7,
    "lines": [
      {
        "index": 0,
        "text": "清明时节雨纷纷，",
        "start": 4.41,
        "end": 6.61,
        "segments": 1
      },
      {
        "index": 1,
        "text": "路上行人欲断魂。",
        "start": 6.84,
        "end": 9.33,
        "segments": 1
      },
      {
        "index": 2,
        "text": "借问酒家何处有，",
        "start": 10.12,
        "end": 12.15,
        "segments": 1
      },
      {
        "index": 3,
        "text": "牧童遥指杏花村。",
        "start": 12.96,
        "end": 15.16,
        "segments": 1
      }
    ]
  },
  "21": {
    "poemId": 21,
    "title": "望庐山瀑布",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.199,
    "skipSegments": 3,
    "segmentCount": 7,
    "lines": [
      {
        "index": 0,
        "text": "日照香炉生紫烟，",
        "start": 5.21,
        "end": 7.26,
        "segments": 1
      },
      {
        "index": 1,
        "text": "遥看瀑布挂前川。",
        "start": 7.66,
        "end": 9.81,
        "segments": 1
      },
      {
        "index": 2,
        "text": "飞流直下三千尺，",
        "start": 10.52,
        "end": 12.74,
        "segments": 1
      },
      {
        "index": 3,
        "text": "疑是银河落九天。",
        "start": 12.88,
        "end": 15.28,
        "segments": 1
      }
    ]
  },
  "91": {
    "poemId": 91,
    "title": "题西林壁",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.386,
    "skipSegments": 2,
    "segmentCount": 10,
    "lines": [
      {
        "index": 0,
        "text": "横看成岭侧成峰，",
        "start": 3.15,
        "end": 8.96,
        "segments": 2
      },
      {
        "index": 1,
        "text": "远近高低各不同。",
        "start": 9.03,
        "end": 14.15,
        "segments": 2
      },
      {
        "index": 2,
        "text": "不识庐山真面目，",
        "start": 14.52,
        "end": 20.67,
        "segments": 2
      },
      {
        "index": 3,
        "text": "只缘身在此山中。",
        "start": 21.04,
        "end": 25.92,
        "segments": 2
      }
    ]
  }
