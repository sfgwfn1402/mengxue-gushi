{
  "1": {
    "poemId": 1,
    "title": "静夜思",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.177,
    "skipSegments": 3,
    "segmentCount": 7,
    "lines": [
      {
        "index": 0,
        "text": "床前明月光，",
        "start": 4.67,
        "end": 6.35,
        "segments": 1
      },
      {
        "index": 1,
        "text": "疑是地上霜。",
        "start": 6.79,
        "end": 8.27,
        "segments": 1
      },
      {
        "index": 2,
        "text": "举头望明月，",
        "start": 9.03,
        "end": 10.55,
        "segments": 1
      },
      {
        "index": 3,
        "text": "低头思故乡。",
        "start": 10.89,
        "end": 12.41,
        "segments": 1
      }
    ]
  },
  "2": {
    "poemId": 2,
    "title": "春晓",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.2,
    "skipSegments": 3,
    "segmentCount": 9,
    "lines": [
      {
        "index": 0,
        "text": "春眠不觉晓，",
        "start": 5.93,
        "end": 8.94,
        "segments": 1
      },
      {
        "index": 1,
        "text": "处处闻啼鸟。",
        "start": 9.65,
        "end": 13.01,
        "segments": 2
      },
      {
        "index": 2,
        "text": "夜来风雨声，",
        "start": 14.46,
        "end": 17.3,
        "segments": 1
      },
      {
        "index": 3,
        "text": "花落知多少。",
        "start": 17.99,
        "end": 21.85,
        "segments": 2
      }
    ]
  },
  "3": {
    "poemId": 3,
    "title": "登鹳雀楼",
    "lineCount": 4,
    "status": "funasr_aligned",
    "cost": 0.417,
    "skipSegments": 3,
    "segmentCount": 10,
    "lines": [
      {
        "index": 0,
        "text": "白日依山尽，",
        "start": 5.27,
        "end": 7.75,
        "segments": 5,
        "source": "funasr"
      },
      {
        "index": 1,
        "text": "黄河入海流。",
        "start": 9.03,
        "end": 12.05,
        "segments": 5,
        "source": "funasr"
      },
      {
        "index": 2,
        "text": "欲穷千里目，",
        "start": 13.71,
        "end": 15.69,
        "segments": 5,
        "source": "funasr"
      },
      {
        "index": 3,
        "text": "更上一层楼。",
        "start": 16.55,
        "end": 19.86,
        "segments": 5,
        "source": "funasr"
      }
    ]
  },
  "6": {
    "poemId": 6,
    "title": "悯农",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.088,
    "skipSegments": 4,
    "segmentCount": 8,
    "lines": [
      {
        "index": 0,
        "text": "锄禾日当午，",
        "start": 6.05,
        "end": 7.68,
        "segments": 1
      },
      {
        "index": 1,
        "text": "汗滴禾下土。",
        "start": 8.07,
        "end": 9.79,
        "segments": 1
      },
      {
        "index": 2,
