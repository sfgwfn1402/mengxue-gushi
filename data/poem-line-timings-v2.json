  "8": {
    "poemId": 8,
    "title": "游子吟",
    "lineCount": 6,
    "status": "funasr_aligned_v3_id8_textfix",
    "matchRatio": 1,
    "weakLines": 0,
    "recognizedText": "游子吟，孟郊，唐代慈母手中线游子身上衣，临行密密缝，意恐迟迟归，谁言寸草心，报得三春晖。",
    "lines": [
      {
        "index": 0,
        "text": "慈母手中线，",
        "start": 4.65,
        "end": 6.25,
        "segments": 5,
        "source": "funasr_align"
      },
      {
        "index": 1,
        "text": "游子身上衣。",
        "start": 6.69,
        "end": 8.229,
        "segments": 5,
        "source": "funasr_align"
      },
      {
        "index": 2,
        "text": "临行密密缝，",
        "start": 9.01,
        "end": 10.55,
        "segments": 5,
        "source": "funasr_align"
      },
      {
        "index": 3,
        "text": "意恐迟迟归。",
        "start": 10.93,
        "end": 12.53,
        "segments": 5,
        "source": "funasr_align"
      },
      {
        "index": 4,
        "text": "谁言寸草心，",
        "start": 13.27,
        "end": 14.91,
        "segments": 5,
        "source": "funasr_align"
      },
      {
        "index": 5,
        "text": "报得三春晖。",
        "start": 15.27,
        "end": 17.395,
        "segments": 5,
        "source": "funasr_align"
      }
    ]
  },
