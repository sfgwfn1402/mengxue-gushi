{
  "1": {
    "poemId": 1,
    "title": "静夜思",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.177,
    "skipSegments": 3,
    "segmentCount": 7,
    "lines": [
      {
        "index": 0,
        "text": "床前明月光，",
        "start": 4.67,
        "end": 6.35,
        "segments": 1
      },
      {
        "index": 1,
        "text": "疑是地上霜。",
        "start": 6.79,
        "end": 8.27,
        "segments": 1
      },
      {
        "index": 2,
        "text": "举头望明月，",
        "start": 9.03,
        "end": 10.55,
        "segments": 1
      },
      {
        "index": 3,
        "text": "低头思故乡。",
        "start": 10.89,
        "end": 12.41,
        "segments": 1
      }
    ]
  },
  "2": {
    "poemId": 2,
    "title": "春晓",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.2,
    "skipSegments": 3,
    "segmentCount": 9,
    "lines": [
      {
        "index": 0,
        "text": "春眠不觉晓，",
        "start": 5.93,
        "end": 8.94,
        "segments": 1
      },
      {
        "index": 1,
        "text": "处处闻啼鸟。",
        "start": 9.65,
        "end": 13.01,
        "segments": 2
      },
      {
        "index": 2,
        "text": "夜来风雨声，",
        "start": 14.46,
        "end": 17.3,
        "segments": 1
      },
      {
        "index": 3,
        "text": "花落知多少。",
        "start": 17.99,
        "end": 21.85,
        "segments": 2
      }
    ]
  },
  "3": {
    "poemId": 3,
    "title": "登鹳雀楼",
    "lineCount": 4,
    "status": "funasr_aligned",
    "cost": 0.417,
    "skipSegments": 3,
    "segmentCount": 10,
    "lines": [
      {
        "index": 0,
        "text": "白日依山尽，",
        "start": 5.27,
        "end": 7.75,
        "segments": 5,
        "source": "funasr"
      },
      {
        "index": 1,
        "text": "黄河入海流。",
        "start": 9.03,
        "end": 12.05,
        "segments": 5,
        "source": "funasr"
      },
      {
        "index": 2,
        "text": "欲穷千里目，",
        "start": 13.71,
        "end": 15.69,
        "segments": 5,
        "source": "funasr"
      },
      {
        "index": 3,
        "text": "更上一层楼。",
        "start": 16.55,
        "end": 19.86,
        "segments": 5,
        "source": "funasr"
      }
    ]
  },
  "6": {
    "poemId": 6,
    "title": "悯农",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.088,
    "skipSegments": 4,
    "segmentCount": 8,
    "lines": [
      {
        "index": 0,
        "text": "锄禾日当午，",
        "start": 6.05,
        "end": 7.68,
        "segments": 1
      },
      {
        "index": 1,
        "text": "汗滴禾下土。",
        "start": 8.07,
        "end": 9.79,
        "segments": 1
      },
      {
        "index": 2,
        "text": "谁知盘中餐，",
        "start": 10.51,
        "end": 12.19,
        "segments": 1
      },
      {
        "index": 3,
        "text": "粒粒皆辛苦。",
        "start": 12.56,
        "end": 14.2,
        "segments": 1
      }
    ]
  },
  "7": {
    "poemId": 7,
    "title": "江雪",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.32,
    "skipSegments": 3,
    "segmentCount": 7,
    "lines": [
      {
        "index": 0,
        "text": "千山鸟飞绝，",
        "start": 4.88,
        "end": 6.56,
        "segments": 1
      },
      {
        "index": 1,
        "text": "万径人踪灭。",
        "start": 6.95,
        "end": 8.55,
        "segments": 1
      },
      {
        "index": 2,
        "text": "孤舟蓑笠翁，",
        "start": 9.34,
        "end": 10.69,
        "segments": 1
      },
      {
        "index": 3,
        "text": "独钓寒江雪。",
        "start": 11.12,
        "end": 12.85,
        "segments": 1
      }
    ]
  },
  "8": {
    "poemId": 8,
    "title": "游子吟",
    "lineCount": 4,
    "status": "ok_v2",
    "cost": 0.216,
    "skipSegments": 5,
    "segmentCount": 9,
    "lines": [
      {
        "index": 0,
        "text": "慈母手中线，",
        "start": 9.04,
        "end": 10.72,
        "segments": 1
      },
      {
        "index": 1,
        "text": "游子身上衣。",
        "start": 11.04,
        "end": 12.58,
        "segments": 1
      },
      {
        "index": 2,
        "text": "临行密密缝，",
        "start": 13.31,
        "end": 15.01,
        "segments": 1
      },
      {
        "index": 3,
        "text": "意恐迟迟归。",
        "start": 15.43,
        "end": 16.95,
        "segments": 1
      }
    ]
  },
