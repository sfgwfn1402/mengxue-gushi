{
  "1": {
    "poemId": 1,
    "title": "静夜思",
    "lineCount": 4,
    "segmentCount": 7,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "床前明月光，",
        "start": 4.67,
        "end": 6.35
      },
      {
        "index": 1,
        "text": "疑是地上霜。",
        "start": 6.79,
        "end": 8.27
      },
      {
        "index": 2,
        "text": "举头望明月，",
        "start": 9.03,
        "end": 10.55
      },
      {
        "index": 3,
        "text": "低头思故乡。",
        "start": 10.89,
        "end": 12.41
      }
    ]
  },
  "2": {
    "poemId": 2,
    "title": "春晓",
    "lineCount": 4,
    "segmentCount": 9,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "春眠不觉晓，",
        "start": 11.06,
        "end": 13.01
      },
      {
        "index": 1,
        "text": "处处闻啼鸟。",
        "start": 14.46,
        "end": 17.3
      },
      {
        "index": 2,
        "text": "夜来风雨声，",
        "start": 17.99,
        "end": 19.3
      },
      {
        "index": 3,
        "text": "花落知多少。",
        "start": 19.68,
        "end": 21.85
      }
    ]
  },
  "3": {
    "poemId": 3,
    "title": "登鹳雀楼",
    "lineCount": 4,
    "segmentCount": 9,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "白日依山尽，",
        "start": 10.5,
        "end": 12.53
      },
      {
        "index": 1,
        "text": "黄河入海流。",
        "start": 13.79,
        "end": 16.25
      },
      {
        "index": 2,
        "text": "欲穷千里目，",
        "start": 16.47,
        "end": 17.82
      },
      {
        "index": 3,
        "text": "更上一层楼。",
        "start": 17.99,
        "end": 19.68
      }
    ]
  },
  "6": {
    "poemId": 6,
    "title": "悯农",
    "lineCount": 4,
    "segmentCount": 8,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "锄禾日当午，",
        "start": 6.05,
        "end": 7.68
      },
      {
        "index": 1,
        "text": "汗滴禾下土。",
        "start": 8.07,
        "end": 9.79
      },
      {
        "index": 2,
        "text": "谁知盘中餐，",
        "start": 10.51,
        "end": 12.19
      },
      {
        "index": 3,
        "text": "粒粒皆辛苦。",
        "start": 12.56,
        "end": 14.2
      }
    ]
  },
  "7": {
    "poemId": 7,
    "title": "江雪",
    "lineCount": 4,
    "segmentCount": 7,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "千山鸟飞绝，",
        "start": 4.88,
        "end": 6.56
      },
      {
        "index": 1,
        "text": "万径人踪灭。",
        "start": 6.95,
        "end": 8.55
      },
      {
        "index": 2,
        "text": "孤舟蓑笠翁，",
        "start": 9.34,
        "end": 10.69
      },
      {
        "index": 3,
        "text": "独钓寒江雪。",
        "start": 11.12,
        "end": 12.85
      }
    ]
  },
  "8": {
    "poemId": 8,
    "title": "游子吟",
    "lineCount": 4,
    "segmentCount": 9,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "慈母手中线，",
        "start": 9.04,
        "end": 10.72
      },
      {
        "index": 1,
        "text": "游子身上衣。",
        "start": 11.04,
        "end": 12.58
      },
      {
        "index": 2,
        "text": "临行密密缝，",
        "start": 13.31,
        "end": 15.01
      },
      {
        "index": 3,
        "text": "意恐迟迟归。",
        "start": 15.43,
        "end": 16.95
      }
    ]
  },
  "9": {
    "poemId": 9,
    "title": "咏鹅",
    "lineCount": 6,
    "segmentCount": 9,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "鹅，",
        "start": 7.63,
        "end": 9.34
      },
      {
        "index": 1,
        "text": "鹅，",
        "start": 10.34,
        "end": 11.48
      },
      {
        "index": 2,
        "text": "鹅，",
        "start": 11.79,
        "end": 13.67
      },
      {
        "index": 3,
        "text": "曲项向天歌。",
        "start": 15.2,
        "end": 17.68
      },
      {
        "index": 4,
        "text": "白毛浮绿水，",
        "start": 18.4,
        "end": 19.54
      },
      {
        "index": 5,
        "text": "红掌拨清波。",
        "start": 20.16,
        "end": 22.19
      }
    ]
  },
  "10": {
    "poemId": 10,
    "title": "清明",
    "lineCount": 4,
    "segmentCount": 7,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "清明时节雨纷纷，",
        "start": 4.41,
        "end": 6.61
      },
      {
        "index": 1,
        "text": "路上行人欲断魂。",
        "start": 6.84,
        "end": 9.33
      },
      {
        "index": 2,
        "text": "借问酒家何处有，",
        "start": 10.12,
        "end": 12.15
      },
      {
        "index": 3,
        "text": "牧童遥指杏花村。",
        "start": 12.96,
        "end": 15.16
      }
    ]
  },
  "21": {
    "poemId": 21,
    "title": "望庐山瀑布",
    "lineCount": 4,
    "segmentCount": 7,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "日照香炉生紫烟，",
        "start": 5.21,
        "end": 7.26
      },
      {
        "index": 1,
        "text": "遥看瀑布挂前川。",
        "start": 7.66,
        "end": 9.81
      },
      {
        "index": 2,
        "text": "飞流直下三千尺，",
        "start": 10.52,
        "end": 12.74
      },
      {
        "index": 3,
        "text": "疑是银河落九天。",
        "start": 12.88,
        "end": 15.28
      }
    ]
  },
  "91": {
    "poemId": 91,
    "title": "题西林壁",
    "lineCount": 4,
    "segmentCount": 9,
    "status": "ok",
    "lines": [
      {
        "index": 0,
        "text": "横看成岭侧成峰，",
        "start": 14.52,
        "end": 16.1
      },
      {
        "index": 1,
        "text": "远近高低各不同。",
        "start": 17.46,
        "end": 20.67
      },
      {
        "index": 2,
        "text": "不识庐山真面目，",
        "start": 21.04,
        "end": 23.48
      },
      {
        "index": 3,
        "text": "只缘身在此山中。",
        "start": 23.68,
        "end": 25.92
      }
    ]
  }
}
