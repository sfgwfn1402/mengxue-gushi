{
  "poems": [
    {
      "id": 21,
      "title": "望庐山瀑布",
      "author": "李白",
      "dynasty": "唐",
      "content": "日照香炉生紫烟，遥看瀑布挂前川。飞流直下三千尺，疑是银河落九天。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "风景",
        "瀑布",
        "庐山",
        "壮观"
      ],
      "season": "summer"
    },
    {
      "id": 22,
      "title": "赠汪伦",
      "author": "李白",
      "dynasty": "唐",
      "content": "李白乘舟将欲行，忽闻涛声踏歌声。桃花潭水深千尺，不及汪伦送我情。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "友情",
        "送别",
        "桃花潭",
        "情谊"
      ],
      "season": "spring"
    },
    {
      "id": 23,
      "title": "登幽州台歌",
      "author": "陈子昂",
      "dynasty": "唐",
      "content": "前不见古人，后不见来者。念天地之悠悠，独怆然而泪下。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "怀才不遇",
        "悲伤",
        "时间",
        "哲理"
      ],
      "season": "any"
    },
    {
      "id": 24,
      "title": "出塞",
      "author": "王昌龄",
      "dynasty": "唐",
      "content": "秦时明月汉时关，万里长征人未还。但使龙城飞将在，不教胡马度阴山。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "边塞",
        "战争",
        "保家卫国",
        "月亮"
      ],
      "season": "any"
    },
    {
      "id": 25,
      "title": "题临安邸",
      "author": "林升",
      "dynasty": "宋",
      "content": "山外青山楼外楼，西湖歌舞几时休。暖风熏得游人醉，直把杭州作汴州。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "讽刺",
        "西湖",
        "歌舞",
        "忧国"
      ],
      "season": "spring"
    },
    {
      "id": 26,
      "title": "秋夜将晓出篱门迎凉有感",
      "author": "陆游",
      "dynasty": "宋",
      "content": "三万里河东入海，五千仞岳上摩天。遗民泪尽胡尘里，南望王师又一年。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "爱国",
        "收复失地",
        "黄河",
        "华山"
      ],
      "season": "autumn"
    },
    {
      "id": 27,
      "title": "示儿",
      "author": "陆游",
      "dynasty": "宋",
      "content": "死去元知万事空，但悲不见九州同。王师北定中原日，家祭无忘告乃翁。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "爱国",
        "遗嘱",
        "统一",
        "家国"
      ],
      "season": "any"
    },
    {
      "id": 28,
      "title": "游园不值",
      "author": "叶绍翁",
      "dynasty": "宋",
      "content": "应怜屐齿印苍苔，小扣柴扉久不开。春色满园关不住，一枝红杏出墙来。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "花园",
        "红杏",
        "景色"
      ],
      "season": "spring"
    },
    {
      "id": 29,
      "title": "墨梅",
      "author": "王冕",
      "dynasty": "元",
      "content": "吾家洗砚池头树，朵朵花开淡墨痕。不要人夸好颜色，只留清气满乾坤。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "梅花",
        "品格",
        "清白",
        "墨梅"
      ],
      "season": "winter"
    },
    {
      "id": 30,
      "title": "石灰吟",
      "author": "于谦",
      "dynasty": "明",
      "content": "千锤万凿出深山，烈火焚烧若等闲。粉骨碎身浑不怕，要留清白在人间。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "石灰",
        "品格",
        "清白",
        "坚强"
      ],
      "season": "any",
      "pinyin": "qiān chuí wàn záo chū shēn shān, liè huǒ fén shāo ruò děng xián. fěn gǔ suì shēn hún bù pà, yào liú qīng bái zài rén jiān."
    },
    {
      "id": 31,
      "title": "竹石",
      "author": "郑燮",
      "dynasty": "清",
      "content": "咬定青山不放松，立根原在破岩中。千磨万击还坚劲，任尔东西南北风。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "竹子",
        "坚强",
        "品格",
        "节气"
      ],
      "season": "any"
    },
    {
      "id": 32,
      "title": "宿新市徐公店",
      "author": "杨万里",
      "dynasty": "宋",
      "content": "篱落疏疏一径深，树头花落未成阴。儿童急走追黄蝶，飞入菜花无处寻。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "童年",
        "春天",
        "蝴蝶",
        "乡村"
      ],
      "season": "spring"
    },
    {
      "id": 33,
      "title": "四时田园杂兴",
      "author": "范成大",
      "dynasty": "宋",
      "content": "昼出耘田夜绩麻，村庄儿女各当家。童孙未解供耕织，也傍桑阴学种瓜。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "田园",
        "劳动",
        "农村",
        "童年"
      ],
      "season": "summer",
      "pinyin": "zhòu chū yún tián yè jì má, cūn zhuāng ér nǚ gè dāng jiā. tóng sūn wèi jiě gōng gēng zhī, yě bàng sāng yīn xué zhòng guā.",
