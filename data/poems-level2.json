    {
      "id": 34,
      "title": "忆江南",
      "author": "白居易",
      "dynasty": "唐",
      "content": "江南好，风景旧曾谙。日出江花红胜火，春来江水绿如蓝。能不忆江南。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "江南",
        "风景",
        "春天",
        "回忆"
      ],
      "season": "spring"
    },
    {
      "id": 35,
      "title": "泊船瓜洲",
      "author": "王安石",
      "dynasty": "宋",
      "content": "京口瓜洲一水间，钟山只隔数重山。春风又绿江南岸，明月何时照我还。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "思乡",
        "春天",
        "明月",
        "船"
      ],
      "season": "spring"
    },
    {
      "id": 65,
      "title": "蜂",
      "author": "罗隐",
      "dynasty": "唐",
      "content": "不论平地与山尖，无限风光尽被占。采得百花成蜜后，为谁辛苦为谁甜？",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "蜜蜂",
        "劳动",
        "思考"
      ],
      "season": "spring"
    },
    {
      "id": 66,
      "title": "早发白帝城",
      "author": "李白",
      "dynasty": "唐",
      "content": "朝辞白帝彩云间，千里江陵一日还。两岸猿声啼不住，轻舟已过万重山。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "长江",
        "旅行",
        "轻快"
      ],
      "season": "any"
    },
    {
      "id": 67,
      "title": "望庐山瀑布",
      "author": "李白",
      "dynasty": "唐",
      "content": "日照香炉生紫烟，遥看瀑布挂前川。飞流直下三千尺，疑是银河落九天。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "瀑布",
        "庐山",
        "想象"
      ],
      "season": "summer"
    },
    {
      "id": 69,
      "title": "黄鹤楼送孟浩然之广陵",
      "author": "李白",
      "dynasty": "唐",
      "content": "故人西辞黄鹤楼，烟花三月下扬州。孤帆远影碧空尽，唯见长江天际流。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "送别",
        "长江",
        "友情"
      ],
      "season": "spring"
    },
    {
      "id": 72,
      "title": "江畔独步寻花",
      "author": "杜甫",
      "dynasty": "唐",
      "content": "黄师塔前江水东，春光懒困倚微风。桃花一簇开无主，可爱深红爱浅红。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "桃花",
        "江边"
      ],
      "season": "spring"
    },
    {
      "id": 73,
      "title": "枫桥夜泊",
      "author": "张继",
      "dynasty": "唐",
      "content": "月落乌啼霜满天，江枫渔火对愁眠。姑苏城外寒山寺，夜半钟声到客船。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "夜晚",
        "钟声",
        "旅行"
      ],
      "season": "autumn"
    },
    {
      "id": 74,
      "title": "游子吟",
      "author": "孟郊",
      "dynasty": "唐",
      "content": "慈母手中线，游子身上衣。临行密密缝，意恐迟迟归。谁言寸草心，报得三春晖。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "母爱",
        "亲情",
        "游子"
      ],
      "season": "any"
    },
    {
      "id": 75,
      "title": "竹枝词",
      "author": "刘禹锡",
      "dynasty": "唐",
      "content": "杨柳青青江水平，闻郎江上唱歌声。东边日出西边雨，道是无晴却有晴。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "江边",
        "民歌",
        "杨柳"
      ],
      "season": "spring"
    },
    {
      "id": 76,
      "title": "乌衣巷",
      "author": "刘禹锡",
      "dynasty": "唐",
      "content": "朱雀桥边野草花，乌衣巷口夕阳斜。旧时王谢堂前燕，飞入寻常百姓家。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "历史",
        "燕子"
      ],
      "season": "spring"
    },
    {
      "id": 77,
      "title": "浪淘沙",
      "author": "刘禹锡",
      "dynasty": "唐",
      "content": "九曲黄河万里沙，浪淘风簸自天涯。如今直上银河去，同到牵牛织女家。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "黄河",
        "想象"
      ],
      "season": "any"
    },
    {
      "id": 78,
      "title": "秋词",
      "author": "刘禹锡",
      "dynasty": "唐",
      "content": "自古逢秋悲寂寥，我言秋日胜春朝。晴空一鹤排云上，便引诗情到碧霄。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "秋天",
        "乐观"
      ],
      "season": "autumn"
    },
    {
      "id": 79,
      "title": "题都城南庄",
      "author": "崔护",
      "dynasty": "唐",
      "content": "去年今日此门中，人面桃花相映红。人面不知何处去，桃花依旧笑春风。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "桃花",
        "春天"
      ],
      "season": "spring"
    },
    {
      "id": 82,
      "title": "江南春",
      "author": "杜牧",
      "dynasty": "唐",
      "content": "千里莺啼绿映红，水村山郭酒旗风。南朝四百八十寺，多少楼台烟雨中。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "江南",
        "春天",
        "烟雨"
      ],
      "season": "spring"
    },
    {
      "id": 84,
      "title": "乐游原",
      "author": "李商隐",
      "dynasty": "唐",
      "content": "向晚意不适，驱车登古原。夕阳无限好，只是近黄昏。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "夕阳",
        "哲理"
      ],
      "season": "autumn"
    },
    {
      "id": 85,
      "title": "夜雨寄北",
      "author": "李商隐",
      "dynasty": "唐",
      "content": "君问归期未有期，巴山夜雨涨秋池。何当共剪西窗烛，却话巴山夜雨时。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "思念",
        "夜雨"
      ],
      "season": "autumn"
    },
    {
      "id": 88,
      "title": "泊船瓜洲",
      "author": "王安石",
      "dynasty": "宋",
      "content": "京口瓜洲一水间，钟山只隔数重山。春风又绿江南岸，明月何时照我还？",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "思乡"
      ],
      "season": "spring"
    },
    {
      "id": 89,
      "title": "书湖阴先生壁",
      "author": "王安石",
      "dynasty": "宋",
      "content": "茅檐长扫净无苔，花木成畦手自栽。一水护田将绿绕，两山排闼送青来。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "乡村",
        "自然"
      ],
      "season": "spring"
    },
    {
      "id": 90,
      "title": "饮湖上初晴后雨",
      "author": "苏轼",
      "dynasty": "宋",
      "content": "水光潋滟晴方好，山色空蒙雨亦奇。欲把西湖比西子，淡妆浓抹总相宜。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "西湖",
        "雨",
        "风景"
      ],
      "season": "summer"
    },
    {
      "id": 91,
      "title": "题西林壁",
      "author": "苏轼",
      "dynasty": "宋",
      "content": "横看成岭侧成峰，远近高低各不同。不识庐山真面目，只缘身在此山中。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "庐山",
        "哲理"
      ],
      "season": "any"
    },
    {
      "id": 93,
      "title": "六月二十七日望湖楼醉书",
      "author": "苏轼",
      "dynasty": "宋",
      "content": "黑云翻墨未遮山，白雨跳珠乱入船。卷地风来忽吹散，望湖楼下水如天。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "夏雨",
        "西湖"
      ],
      "season": "summer"
    },
    {
      "id": 95,
      "title": "如梦令",
      "author": "李清照",
      "dynasty": "宋",
      "content": "常记溪亭日暮，沉醉不知归路。兴尽晚回舟，误入藕花深处。争渡，争渡，惊起一滩鸥鹭。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "荷花",
        "游玩"
      ],
      "season": "summer"
    },
    {
      "id": 97,
      "title": "游山西村",
      "author": "陆游",
      "dynasty": "宋",
      "content": "莫笑农家腊酒浑，丰年留客足鸡豚。山重水复疑无路，柳暗花明又一村。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "乡村",
        "希望"
      ],
      "season": "spring"
    },
    {
      "id": 101,
      "title": "登科后",
      "author": "孟郊",
      "dynasty": "唐",
      "content": "昔日龌龊不足夸，今朝放荡思无涯。春风得意马蹄疾，一日看尽长安花。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "喜悦",
        "人生"
      ],
      "season": "spring"
    },
    {
      "id": 102,
      "title": "劝学",
      "author": "颜真卿",
      "dynasty": "唐",
      "content": "三更灯火五更鸡，正是男儿读书时。黑发不知勤学早，白首方悔读书迟。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "勤学",
        "惜时",
        "成长"
      ],
      "season": "any"
    },
    {
      "id": 103,
      "title": "金缕衣",
      "author": "杜秋娘",
      "dynasty": "唐",
      "content": "劝君莫惜金缕衣，劝君惜取少年时。花开堪折直须折，莫待无花空折枝。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "惜时",
        "成长",
        "花"
      ],
      "season": "spring"
    },
    {
      "id": 104,
      "title": "剑客",
      "author": "贾岛",
      "dynasty": "唐",
      "content": "十年磨一剑，霜刃未曾试。今日把示君，谁有不平事。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "志向",
        "侠义",
        "品格"
      ],
      "season": "winter"
    },
    {
      "id": 106,
      "title": "农家",
      "author": "颜仁郁",
      "dynasty": "唐",
      "content": "半夜呼儿趁晓耕，羸牛无力渐艰行。时人不识农家苦，将谓田中谷自生。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "劳动",
        "农事",
        "节约"
      ],
      "season": "any"
    },
    {
      "id": 107,
      "title": "蚕妇",
      "author": "张俞",
      "dynasty": "宋",
      "content": "昨日入城市，归来泪满巾。遍身罗绮者，不是养蚕人。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "劳动",
        "悲悯",
        "生活"
      ],
      "season": "any"
    },
    {
      "id": 108,
      "title": "陶者",
      "author": "梅尧臣",
      "dynasty": "宋",
      "content": "陶尽门前土，屋上无片瓦。十指不沾泥，鳞鳞居大厦。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "劳动",
        "悲悯",
        "生活"
      ],
      "season": "any"
    },
    {
      "id": 109,
      "title": "乡村四月",
      "author": "翁卷",
      "dynasty": "宋",
      "content": "绿遍山原白满川，子规声里雨如烟。乡村四月闲人少，才了蚕桑又插田。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "乡村",
        "劳动",
        "春天"
      ],
      "season": "spring"
    },
    {
      "id": 110,
      "title": "约客",
      "author": "赵师秀",
      "dynasty": "宋",
      "content": "黄梅时节家家雨，青草池塘处处蛙。有约不来过夜半，闲敲棋子落灯花。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "夏天",
        "雨",
        "生活"
      ],
      "season": "summer"
    },
    {
      "id": 111,
      "title": "秋夕",
      "author": "杜牧",
      "dynasty": "唐",
      "content": "银烛秋光冷画屏，轻罗小扇扑流萤。天阶夜色凉如水，卧看牵牛织女星。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "秋天",
        "夜晚",
        "星空"
      ],
      "season": "autumn"
    },
    {
      "id": 115,
      "title": "嫦娥",
      "author": "李商隐",
      "dynasty": "唐",
      "content": "云母屏风烛影深，长河渐落晓星沉。嫦娥应悔偷灵药，碧海青天夜夜心。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "月夜",
        "神话",
        "想象"
      ],
      "season": "autumn"
    },
    {
      "id": 120,
      "title": "送灵澈上人",
      "author": "刘长卿",
      "dynasty": "唐",
      "content": "苍苍竹林寺，杳杳钟声晚。荷笠带斜阳，青山独归远。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "送别",
        "山林",
        "夕阳"
      ],
      "season": "any"
    },
    {
      "id": 122,
      "title": "渡汉江",
      "author": "宋之问",
      "dynasty": "唐",
      "content": "岭外音书断，经冬复历春。近乡情更怯，不敢问来人。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "思乡",
        "春天",
        "旅途"
      ],
      "season": "spring"
    },
    {
      "id": 128,
      "title": "送元二使安西",
      "author": "王维",
      "dynasty": "唐",
      "content": "渭城朝雨浥轻尘，客舍青青柳色新。劝君更尽一杯酒，西出阳关无故人。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "送别",
        "友情",
        "春天"
      ],
      "season": "spring"
    },
    {
      "id": 129,
      "title": "山中",
      "author": "王维",
      "dynasty": "唐",
      "content": "荆溪白石出，天寒红叶稀。山路元无雨，空翠湿人衣。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "山水",
        "秋天",
        "冬天"
      ],
      "season": "autumn"
    },
    {
      "id": 132,
      "title": "秋浦歌",
      "author": "李白",
      "dynasty": "唐",
      "content": "白发三千丈，缘愁似个长。不知明镜里，何处得秋霜。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "秋天",
        "想象",
        "人生"
      ],
      "season": "autumn"
    },
    {
      "id": 134,
      "title": "峨眉山月歌",
      "author": "李白",
      "dynasty": "唐",
      "content": "峨眉山月半轮秋，影入平羌江水流。夜发清溪向三峡，思君不见下渝州。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "月夜",
        "秋天",
        "旅行"
      ],
      "season": "autumn"
    },
    {
      "id": 135,
      "title": "山中问答",
      "author": "李白",
      "dynasty": "唐",
      "content": "问余何意栖碧山，笑而不答心自闲。桃花流水窅然去，别有天地非人间。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "山水",
        "春天",
        "闲适"
      ],
      "season": "spring"
    },
    {
      "id": 137,
      "title": "春夜洛城闻笛",
      "author": "李白",
      "dynasty": "唐",
      "content": "谁家玉笛暗飞声，散入春风满洛城。此夜曲中闻折柳，何人不起故园情。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "思乡",
        "春天",
        "音乐"
      ],
      "season": "spring"
    },
    {
      "id": 138,
      "title": "逢入京使",
      "author": "岑参",
      "dynasty": "唐",
      "content": "故园东望路漫漫，双袖龙钟泪不干。马上相逢无纸笔，凭君传语报平安。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "思乡",
        "边塞",
        "亲情"
      ],
      "season": "any"
    },
    {
      "id": 140,
      "title": "别董大",
      "author": "高适",
      "dynasty": "唐",
      "content": "千里黄云白日曛，北风吹雁雪纷纷。莫愁前路无知己，天下谁人不识君。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "送别",
        "友情",
        "冬天"
      ],
      "season": "winter"
    },
    {
      "id": 141,
      "title": "塞下曲",
      "author": "卢纶",
      "dynasty": "唐",
      "content": "月黑雁飞高，单于夜遁逃。欲将轻骑逐，大雪满弓刀。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "边塞",
        "战争",
        "冬天"
      ],
      "season": "winter"
    },
    {
      "id": 142,
      "title": "塞下曲其二",
      "author": "卢纶",
      "dynasty": "唐",
      "content": "林暗草惊风，将军夜引弓。平明寻白羽，没在石棱中。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "边塞",
        "战争",
        "勇敢"
      ],
      "season": "any"
    },
    {
      "id": 143,
      "title": "寒食",
      "author": "韩翃",
      "dynasty": "唐",
      "content": "春城无处不飞花，寒食东风御柳斜。日暮汉宫传蜡烛，轻烟散入五侯家。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "节日",
        "春天",
        "历史"
      ],
      "season": "spring"
    },
    {
      "id": 144,
      "title": "滁州西涧",
      "author": "韦应物",
      "dynasty": "唐",
      "content": "独怜幽草涧边生，上有黄鹂深树鸣。春潮带雨晚来急，野渡无人舟自横。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "山水",
        "雨"
      ],
      "season": "spring"
    },
    {
      "id": 145,
      "title": "秋思",
      "author": "张籍",
      "dynasty": "唐",
      "content": "洛阳城里见秋风，欲作家书意万重。复恐匆匆说不尽，行人临发又开封。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "思乡",
        "秋天",
        "亲情"
      ],
      "season": "autumn"
    },
    {
      "id": 146,
      "title": "十五夜望月",
      "author": "王建",
      "dynasty": "唐",
      "content": "中庭地白树栖鸦，冷露无声湿桂花。今夜月明人尽望，不知秋思落谁家。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "中秋",
        "月夜",
        "思乡"
      ],
      "season": "autumn"
    },
    {
      "id": 147,
      "title": "雨过山村",
      "author": "王建",
      "dynasty": "唐",
      "content": "雨里鸡鸣一两家，竹溪村路板桥斜。妇姑相唤浴蚕去，闲看中庭栀子花。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "乡村",
        "雨",
        "劳动"
      ],
      "season": "spring"
    },
    {
      "id": 148,
      "title": "新嫁娘词",
      "author": "王建",
      "dynasty": "唐",
      "content": "三日入厨下，洗手作羹汤。未谙姑食性，先遣小姑尝。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "生活",
        "家庭",
        "习俗"
      ],
      "season": "any"
    },
    {
      "id": 151,
      "title": "芙蓉楼送辛渐",
      "author": "王昌龄",
      "dynasty": "唐",
      "content": "寒雨连江夜入吴，平明送客楚山孤。洛阳亲友如相问，一片冰心在玉壶。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "送别",
        "友情",
        "品格"
      ],
      "season": "any"
    },
    {
      "id": 152,
      "title": "采莲曲",
      "author": "王昌龄",
      "dynasty": "唐",
      "content": "荷叶罗裙一色裁，芙蓉向脸两边开。乱入池中看不见，闻歌始觉有人来。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "夏天",
        "荷花",
        "生活"
      ],
      "season": "summer"
    },
    {
      "id": 153,
      "title": "凉州词",
      "author": "王之涣",
      "dynasty": "唐",
      "content": "黄河远上白云间，一片孤城万仞山。羌笛何须怨杨柳，春风不度玉门关。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "边塞",
        "黄河",
        "春天"
      ],
      "season": "spring"
    },
    {
      "id": 154,
      "title": "渔歌子",
      "author": "张志和",
      "dynasty": "唐",
      "content": "西塞山前白鹭飞，桃花流水鳜鱼肥。青箬笠，绿蓑衣，斜风细雨不须归。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "江河",
        "田园"
      ],
      "season": "spring"
    },
    {
      "id": 155,
      "title": "江南逢李龟年",
      "author": "杜甫",
      "dynasty": "唐",
      "content": "岐王宅里寻常见，崔九堂前几度闻。正是江南好风景，落花时节又逢君。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "江南",
        "友情",
        "春天"
      ],
      "season": "spring"
    },
    {
      "id": 157,
      "title": "八阵图",
      "author": "杜甫",
      "dynasty": "唐",
      "content": "功盖三分国，名成八阵图。江流石不转，遗恨失吞吴。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "历史",
        "三国",
        "哲理"
      ],
      "season": "any"
    },
    {
      "id": 159,
      "title": "赠花卿",
      "author": "杜甫",
      "dynasty": "唐",
      "content": "锦城丝管日纷纷，半入江风半入云。此曲只应天上有，人间能得几回闻。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "音乐",
        "成都",
        "赞美"
      ],
      "season": "any"
    },
    {
      "id": 164,
      "title": "大林寺桃花",
      "author": "白居易",
      "dynasty": "唐",
      "content": "人间四月芳菲尽，山寺桃花始盛开。长恨春归无觅处，不知转入此中来。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "春天",
        "桃花",
        "山寺"
      ],
      "season": "spring"
    },
    {
      "id": 167,
      "title": "问刘十九",
      "author": "白居易",
      "dynasty": "唐",
      "content": "绿蚁新醅酒，红泥小火炉。晚来天欲雪，能饮一杯无。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "冬天",
        "友情",
        "生活"
      ],
      "season": "winter"
    },
    {
      "id": 169,
      "title": "村夜",
      "author": "白居易",
      "dynasty": "唐",
      "content": "霜草苍苍虫切切，村南村北行人绝。独出门前望野田，月明荞麦花如雪。",
      "level": 2,
      "difficulty": 2,
      "tags": [
        "秋天",
        "月夜",
        "乡村"
      ],
      "season": "autumn"
    }
  ]
}
